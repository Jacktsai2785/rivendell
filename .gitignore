.DS_Store
*.swp
*~
reports/*.log
reports/maintain-*

# Daily agent reports — regenerated every run, single-device (no cross-device sync).
# Keep version-controlled: workflow-retro-*.md (weekly retros), skill-audit-*.md,
# and .harvest-decisions.json (user accept/dismiss decisions).
reports/harvest-*
reports/test-*
reports/doctor-*
reports/archive/

# Agent runtime state — regenerated by agents, noisy in git status.
# .harvest-decisions.json is intentionally NOT ignored — it holds user accept/dismiss decisions.
reports/.watchdog-state
reports/.harvest-state
reports/.harvest-done
scripts/__pycache__/
dashboard/data/*.db
dashboard/data/*.db-wal
dashboard/data/*.db-shm
data/*.db
data/*.db-wal
data/*.db-shm
__pycache__/
logs/
data/cost-ledger.jsonl
dashboard-next/api/.venv/
node_modules/

# Deploy system
.active-profile
.env
.env.shared
.gstack/

# Local runtime — 機器本地 log 與設定，不進備份
*.log
.claude/settings.local.json
