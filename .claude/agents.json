{
  "agents": {
    "maintain": {
      "type": "shell",
      "description": "每晚維運：部署檢查、權限同步、agent 健康狀態、審計",
      "script": "bin/sk-maintain-cron",
      "schedule": { "type": "daily", "hour": 22, "minute": 0 },
      "logs": "reports/",
      "git": {
        "merge_strategy": "auto",
        "commit_scope": "reports/*.md reports/*.log",
        "forbidden_paths": [".env*", "*.db", ".claude/**"]
      },
      "qa": { "pre_commit": "off" }
    },
    "harvest": {
      "type": "claude",
      "description": "每 8 小時分析近期 Claude 對話，挖掘可複用的 skill 候選",
      "script": "bin/sk-harvest-cron",
      "schedule": { "type": "interval", "interval": 28800 },
      "logs": "reports/",
      "git": {
        "merge_strategy": "auto",
        "commit_scope": "reports/harvest-*.md",
        "forbidden_paths": [".env*", "*.db", ".claude/**"]
      },
      "qa": { "pre_commit": "off" }
    },
    "tester": {
      "type": "shell",
      "description": "每日驗證：50+ skills 結構檢查、dashboard 建置測試、agent 健康狀態",
      "script": "bin/sk-tester-cron",
      "schedule": { "type": "daily", "hour": 6, "minute": 0 },
      "logs": "reports/",
      "git": {
        "merge_strategy": "auto",
        "commit_scope": "reports/test-*.md",
        "forbidden_paths": [".env*", "*.db", ".claude/**", "skills/**"]
      },
      "qa": { "pre_commit": "off" }
    }
  }
}
