#!/usr/bin/env bash
# sk-reports-janitor — Archive old daily reports into reports/archive/YYYY-MM/.
#
# reports/ accumulates 3+ files per day (harvest, test, skill-audit) plus
# weekly retros. After a few months the directory has hundreds of files
# and `ls reports/` becomes unreadable, masking files that genuinely need
# attention (watchdog.log, current-week retros).
#
# This janitor moves any report-style file older than RETAIN_DAYS into
# reports/archive/YYYY-MM/, preserving git history (the file moves stay
# trackable) and keeping the working directory navigable.
#
# Files matched: harvest-*, test-*, skill-audit-*, workflow-retro-*, plus
# their associated -error.log siblings. Hidden state files (.harvest-*,
# .watchdog-state) are NEVER touched. The current week's workflow-retro
# is also preserved so it stays visible.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
REPORT_DIR="$REPO_DIR/reports"
ARCHIVE_BASE="$REPORT_DIR/archive"
LOG_FILE="$REPORT_DIR/janitor.log"
RETAIN_DAYS=30

mkdir -p "$ARCHIVE_BASE"

CURRENT_ISO_WEEK="$(date '+%G-W%V')"
moved=0
log_buffer=""

# find -mtime works in days, but we want predictable behavior — convert to
# the cutoff date and compare lexically against filename dates where possible.
CUTOFF_DATE=$(date -v-"${RETAIN_DAYS}"d '+%Y-%m-%d' 2>/dev/null || date -d "${RETAIN_DAYS} days ago" '+%Y-%m-%d')

# Collect candidates: dated report files under reports/ (not subdirs)
while IFS= read -r f; do
    base=$(basename "$f")

    # Never archive the current week's retro
    if [[ "$base" == "workflow-retro-${CURRENT_ISO_WEEK}.md" ]]; then
        continue
    fi

    # Extract YYYY-MM-DD or YYYY-WNN from filename
    file_date=$(echo "$base" | grep -oE '20[0-9]{2}-[0-9]{2}-[0-9]{2}' | head -1)

    # workflow-retro uses ISO week — derive an approximate date for comparison
    if [ -z "$file_date" ]; then
        iso_week=$(echo "$base" | grep -oE '20[0-9]{2}-W[0-9]{2}' | head -1)
        if [ -n "$iso_week" ]; then
            yr="${iso_week%%-W*}"
            wk="${iso_week##*W}"
            # Approximate: week N ≈ Jan 1 + 7*(N-1) days. Good enough for archival.
            file_date=$(date -j -v"${yr}"y -v0m -v1d -v+"$((10#${wk} * 7))"d '+%Y-%m-%d' 2>/dev/null \
                || date -d "${yr}-01-01 +$((10#${wk} * 7)) days" '+%Y-%m-%d' 2>/dev/null \
                || echo "")
        fi
    fi

    # Skip if we couldn't determine a date — don't accidentally archive things
    [ -z "$file_date" ] && continue

    # Skip if not yet old enough
    [[ "$file_date" > "$CUTOFF_DATE" ]] && continue

    # Move into reports/archive/YYYY-MM/
    yyyymm="${file_date:0:7}"
    target_dir="$ARCHIVE_BASE/$yyyymm"
    mkdir -p "$target_dir"
    mv "$f" "$target_dir/$base"

    log_buffer+="[$(date '+%Y-%m-%d %H:%M:%S')] ARCHIVED $base -> archive/$yyyymm/"$'\n'
    moved=$((moved + 1))
done < <(find "$REPORT_DIR" -maxdepth 1 -type f \( \
    -name 'harvest-*.md' -o \
    -name 'harvest-*-error.log' -o \
    -name 'test-*.md' -o \
    -name 'skill-audit-*.md' -o \
    -name 'workflow-retro-*.md' -o \
    -name 'workflow-retro-*-error.log' \
    \) 2>/dev/null)

if [ -n "$log_buffer" ]; then
    printf '%s' "$log_buffer" >> "$LOG_FILE"
fi

# Stay quiet on healthy / nothing-to-do
exit 0
