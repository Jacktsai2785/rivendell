#!/usr/bin/env bash
# Scheduled session harvest — analyze recent Claude Code sessions for skill candidates.
# Runs frequently (every 8h) but only produces a report when enough new sessions exist.
# Records execution to dashboard DB via sk-exec-lib
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
REPORT_DIR="$REPO_DIR/reports"
NOW="$(date '+%Y-%m-%d_%H%M')"
TODAY="$(date '+%Y-%m-%d')"
PROJECTS_DIR="$HOME/.claude/projects"
STATE_FILE="$REPORT_DIR/.harvest-state"
MIN_SESSIONS=3  # minimum new sessions to trigger a harvest

mkdir -p "$REPORT_DIR"

# Source exec lib for _sk_exec_record_run
source "$REPO_DIR/bin/sk-exec-lib"

# --- Determine time window: since last harvest or 24h, whichever is shorter ---
if [ -f "$STATE_FILE" ]; then
    last_run=$(cat "$STATE_FILE")
    # Find sessions modified after last harvest
    recent_sessions=$(find "$PROJECTS_DIR" -name "*.jsonl" -newer "$STATE_FILE" 2>/dev/null | head -30)
else
    # First run: look at last 24 hours
    recent_sessions=$(find "$PROJECTS_DIR" -name "*.jsonl" -mtime -1 2>/dev/null | head -30)
fi

session_count=0
if [ -n "$recent_sessions" ]; then
    session_count=$(echo "$recent_sessions" | wc -l | tr -d ' ')
fi

# --- Check if enough sessions to justify a harvest ---
if [ "$session_count" -lt "$MIN_SESSIONS" ]; then
    echo "[$NOW] Only $session_count new session(s) since last harvest (need $MIN_SESSIONS). Skipping."
    exit 0
fi

# --- Count unique messages to gauge session depth ---
total_messages=$(python3 -c "
import json, sys
count = 0
for path in sys.argv[1:]:
    try:
        with open(path) as f:
            for line in f:
                try:
                    e = json.loads(line)
                    if e.get('message', {}).get('usage'):
                        count += 1
                except: pass
    except: pass
print(count)
" $recent_sessions)

echo "[$NOW] Found $session_count session(s) with ~$total_messages messages. Running harvest..."

# --- Build project list ---
project_list=$(echo "$recent_sessions" | xargs -I{} dirname {} | xargs -I{} basename {} | sort -u | tr '\n' ', ')

# --- Build prompt ---
PROMPT="You are reviewing recent Claude Code sessions to identify reusable patterns that could become skills.

Session stats: ${session_count} sessions, ~${total_messages} messages, across projects: ${project_list}

Here are the session summaries:

$(for f in $recent_sessions; do
    echo "=== $(basename $(dirname "$f"))/$(basename "$f") ==="
    python3 -c "
import json, sys
with open('$f') as fh:
    for line in fh:
        try:
            e = json.loads(line)
            msg = e.get('message', {})
            role = msg.get('role', '')
            if role == 'user':
                content = msg.get('content', '')
                if isinstance(content, str) and len(content) > 20:
                    print(f'USER: {content[:200]}')
            elif role == 'assistant':
                content = msg.get('content', [])
                if isinstance(content, list):
                    for c in content:
                        if isinstance(c, dict) and c.get('type') == 'tool_use':
                            print(f'TOOL: {c.get(\"name\", \"?\")} → {str(c.get(\"input\", {}))[:150]}')
        except: pass
" 2>/dev/null | tail -50
    echo ""
done)

Analyze these sessions and identify:
1. Repeated multi-step workflows (same sequence of tools used across sessions)
2. Domain knowledge that was applied (API patterns, framework conventions, data formats)
3. Problem-solving patterns that could be codified

Output a structured harvest report in markdown with:
- Session summary (date, projects, key activities, message count)
- Skill candidates rated as Strong/Moderate/Weak
- For each candidate: name, purpose, trigger, category, rationale

Check the existing skills at: $REPO_DIR/skills/
Only suggest skills that don't already exist.

Write the report in Traditional Chinese (繁體中文)."

# --- Run Claude in headless mode ---
start_epoch=$(date +%s)

claude -p "$PROMPT" \
    --output-format text \
    > "$REPORT_DIR/harvest-${TODAY}.md" \
    2> "$REPORT_DIR/harvest-${TODAY}-error.log" \
    && run_exit=0 || run_exit=$?

end_epoch=$(date +%s)

# --- Record run to dashboard DB ---
_sk_exec_record_run "rivendell" "harvest" "$start_epoch" "$end_epoch" \
  "$run_exit" "" "" "" "" "" ""

# --- Update state ---
date '+%Y-%m-%d %H:%M:%S' > "$STATE_FILE"

echo "[$NOW] Harvest complete ($session_count sessions, ~$total_messages msgs). Report: $REPORT_DIR/harvest-${TODAY}.md"
