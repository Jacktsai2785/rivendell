#!/usr/bin/env bash
# Scheduled session harvest — analyze recent Claude Code sessions for skill candidates.
# Runs frequently (every 8h) but only produces a report when enough new sessions exist.
# Records execution to dashboard DB via sk-exec-lib
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_NAME="$(basename "$REPO_DIR")"
REPORT_DIR="$REPO_DIR/reports"
NOW="$(date '+%Y-%m-%d_%H%M')"
TODAY="$(date '+%Y-%m-%d')"
PROJECTS_DIR="$HOME/.claude/projects"
STATE_FILE="$REPORT_DIR/.harvest-state"
HARVESTED_FILE="$REPORT_DIR/.harvest-done"  # tracks already-harvested session paths
MIN_SESSIONS=3

mkdir -p "$REPORT_DIR"
touch "$HARVESTED_FILE"

# Source exec lib for _sk_exec_record_run
source "$REPO_DIR/bin/sk-exec-lib"

# --- Find new sessions (not yet harvested) ---
# 1. Find JSONL files modified since last harvest (or 24h)
# 2. Exclude subagent sessions (noise)
# 3. Exclude already-harvested sessions
if [ -f "$STATE_FILE" ]; then
    candidates=$(find "$PROJECTS_DIR" -name "*.jsonl" -newer "$STATE_FILE" \
        -not -path "*/subagents/*" 2>/dev/null | sort -t/ -k6 || true)
else
    candidates=$(find "$PROJECTS_DIR" -name "*.jsonl" -mtime -1 \
        -not -path "*/subagents/*" 2>/dev/null | sort -t/ -k6 || true)
fi

# Filter out already-harvested sessions
recent_sessions=""
session_count=0
while IFS= read -r f; do
    [ -z "$f" ] && continue
    if ! grep -qFx "$f" "$HARVESTED_FILE" 2>/dev/null; then
        recent_sessions+="$f"$'\n'
        session_count=$((session_count + 1))
    fi
    # Cap at 30 sessions per harvest
    [ "$session_count" -ge 30 ] && break
done <<< "$candidates"

# Trim trailing newline
recent_sessions=$(echo "$recent_sessions" | sed '/^$/d')

# --- Check if enough NEW sessions to justify a harvest ---
if [ "$session_count" -lt "$MIN_SESSIONS" ]; then
    echo "[$NOW] Only $session_count new session(s) since last harvest (need $MIN_SESSIONS). Skipping."
    exit 0
fi

# --- Pre-summarize sessions (single Python process, compact output) ---
SESSION_SUMMARY=$(echo "$recent_sessions" | xargs python3 "$REPO_DIR/bin/sk-harvest-summarize" 2>/dev/null) || SESSION_SUMMARY=""
total_messages=$(echo "$SESSION_SUMMARY" | head -1 | grep -oE 'Messages: ~[0-9]+' | grep -oE '[0-9]+' || echo "0")

echo "[$NOW] Found $session_count session(s) with ~$total_messages messages. Running harvest..."

# --- Build prompt ---
PROMPT="You are reviewing recent Claude Code sessions to identify reusable patterns that could become skills.

Here is a pre-summarized digest of ${session_count} recent sessions:

${SESSION_SUMMARY}

Analyze these sessions and identify:
1. Repeated multi-step workflows (same sequence of tools used across sessions)
2. Domain knowledge that was applied (API patterns, framework conventions, data formats)
3. Problem-solving patterns that could be codified

Output a structured harvest report in markdown with:
- Session summary (date, projects, key activities, message count)
- Skill candidates rated as Strong/Moderate/Weak
- For each candidate: name, purpose, trigger, category, rationale

Check the existing skills at: $REPO_DIR/skills/
Only suggest skills that don't already exist.

Write the report in Traditional Chinese (繁體中文)."

# --- Run Claude in headless mode ---
start_epoch=$(date +%s)

# Use timestamped report name to avoid overwriting previous runs
REPORT_FILE="$REPORT_DIR/harvest-${TODAY}.md"

claude -p "$PROMPT" \
    --output-format text \
    < /dev/null \
    > "$REPORT_FILE" \
    2> "$REPORT_DIR/harvest-${TODAY}-error.log" \
    && run_exit=0 || run_exit=$?

end_epoch=$(date +%s)

# --- Record run to dashboard DB ---
_sk_exec_record_run "$PROJECT_NAME" "harvest" "$start_epoch" "$end_epoch" \
  "$run_exit" "" "" "" "" "" ""

# --- Mark sessions as harvested (only on success) ---
if [ "$run_exit" -eq 0 ]; then
    echo "$recent_sessions" >> "$HARVESTED_FILE"
fi

# --- Update state timestamp ---
date '+%Y-%m-%d %H:%M:%S' > "$STATE_FILE"

echo "[$NOW] Harvest complete ($session_count sessions, ~$total_messages msgs). Report: $REPORT_FILE"

exit "$run_exit"
