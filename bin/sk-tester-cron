#!/usr/bin/env bash
# Scheduled tester — validate skills structure, dashboard build, agent health.
# Pure shell, zero Claude API cost.
# Records execution to dashboard DB via sk-exec-lib
set -euo pipefail

REPO_DIR="${REPO_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
PROJECT_NAME="$(basename "$REPO_DIR")"
REPORT_DIR="$REPO_DIR/reports"
TODAY="$(date '+%Y-%m-%d')"
REPORT="$REPORT_DIR/test-${TODAY}.md"
SKILLS_DIR="$REPO_DIR/skills"
SYMLINK_DIR="$HOME/.claude/skills"

mkdir -p "$REPORT_DIR"

# Source exec lib for _sk_exec_record_run
set +e; source "$REPO_DIR/bin/sk-exec-lib" 2>/dev/null || true; set -e

start_epoch=$(date +%s)
total_pass=0
total_fail=0
total_warn=0

# --- Report header ---
cat > "$REPORT" <<EOF
# Test Report — $TODAY

> Generated by \`sk-tester-cron\` (pure shell, zero API cost)

EOF

# ═══════════════════════════════════════════════════════════════
# A. Skill Structure Validation
# ═══════════════════════════════════════════════════════════════

skill_pass=0
skill_fail=0
skill_warn=0
skill_errors=""

for category_dir in "$SKILLS_DIR"/*/; do
  [ ! -d "$category_dir" ] && continue
  category="$(basename "$category_dir")"

  for skill_dir in "$category_dir"*/; do
    [ ! -d "$skill_dir" ] && continue
    skill_name="$(basename "$skill_dir")"
    skill_md="$skill_dir/SKILL.md"

    # Check SKILL.md exists
    if [ ! -f "$skill_md" ]; then
      skill_errors+="| \`$category/$skill_name\` | SKILL.md missing | FAIL |\n"
      skill_fail=$((skill_fail + 1))
      continue
    fi

    # Check frontmatter has name + description
    has_name=$(head -20 "$skill_md" | grep -c '^name:' || true)
    has_desc=$(head -20 "$skill_md" | grep -c '^description:' || true)

    if [ "$has_name" -eq 0 ]; then
      skill_errors+="| \`$category/$skill_name\` | Missing \`name\` in frontmatter | FAIL |\n"
      skill_fail=$((skill_fail + 1))
    elif [ "$has_desc" -eq 0 ]; then
      skill_errors+="| \`$category/$skill_name\` | Missing \`description\` in frontmatter | FAIL |\n"
      skill_fail=$((skill_fail + 1))
    else
      skill_pass=$((skill_pass + 1))
    fi

    # Check symlink exists in ~/.claude/skills/
    if [ ! -L "$SYMLINK_DIR/$skill_name" ]; then
      skill_errors+="| \`$category/$skill_name\` | Symlink missing in \`~/.claude/skills/\` | WARN |\n"
      skill_warn=$((skill_warn + 1))
    elif [ ! -d "$SYMLINK_DIR/$skill_name" ]; then
      skill_errors+="| \`$category/$skill_name\` | Symlink broken in \`~/.claude/skills/\` | FAIL |\n"
      skill_fail=$((skill_fail + 1))
    fi
  done
done

skill_total=$((skill_pass + skill_fail))

cat >> "$REPORT" <<EOF
## A. Skill Structure Validation

**Result:** $skill_pass/$skill_total passed, $skill_fail failed, $skill_warn warnings

EOF

if [ -n "$skill_errors" ]; then
  cat >> "$REPORT" <<EOF
| Skill | Issue | Severity |
|-------|-------|----------|
$(echo -e "$skill_errors")
EOF
else
  echo "All skills passed structural validation." >> "$REPORT"
fi

echo "" >> "$REPORT"

total_pass=$((total_pass + skill_pass))
total_fail=$((total_fail + skill_fail))
total_warn=$((total_warn + skill_warn))

# ═══════════════════════════════════════════════════════════════
# B. Dashboard Build Check
# ═══════════════════════════════════════════════════════════════

cat >> "$REPORT" <<EOF
## B. Dashboard Build Check

EOF

dashboard_dir="$REPO_DIR/dashboard-next"
if [ -d "$dashboard_dir" ] && [ -f "$dashboard_dir/package.json" ]; then
  build_output=""
  build_exit=0
  build_output=$(cd "$dashboard_dir" && npx next build 2>&1) || build_exit=$?

  if [ "$build_exit" -eq 0 ]; then
    echo "**Result:** BUILD SUCCESS" >> "$REPORT"
    total_pass=$((total_pass + 1))
  elif echo "$build_output" | grep -qE "Failed to fetch.*(Google Fonts|Geist)|next/font.*error.*fetch"; then
    # Google Fonts network errors are environmental, not code bugs — treat as WARN
    echo "**Result:** BUILD WARN (Google Fonts network unavailable — flaky environment, not a code error)" >> "$REPORT"
    total_warn=$((total_warn + 1))
  else
    echo "**Result:** BUILD FAILED (exit $build_exit)" >> "$REPORT"
    echo "" >> "$REPORT"
    echo '```' >> "$REPORT"
    echo "$build_output" | tail -30 >> "$REPORT"
    echo '```' >> "$REPORT"
    total_fail=$((total_fail + 1))
  fi
else
  echo "**Result:** SKIP — dashboard-next not found" >> "$REPORT"
  total_warn=$((total_warn + 1))
fi

echo "" >> "$REPORT"

# ═══════════════════════════════════════════════════════════════
# C. Agent Health Check
# ═══════════════════════════════════════════════════════════════

cat >> "$REPORT" <<EOF
## C. Agent Health Check

EOF

agent_errors=""
agent_pass=0
agent_fail=0

# Check all project agents via launchctl
for agent_name in maintain harvest tester doctor; do
  label="com.sk.agent.${PROJECT_NAME}.${agent_name}"
  plist_path="$HOME/Library/LaunchAgents/${label}.plist"

  if ! launchctl list "$label" &>/dev/null; then
    agent_errors+="| \`$agent_name\` | Not loaded in launchd | FAIL |\n"
    agent_fail=$((agent_fail + 1))
    continue
  fi

  # Check exit code — launchctl list <label> returns LastExitStatus as raw POSIX
  # wait() value (exit_code << 8), so decode it before comparing
  exit_status=$(launchctl list "$label" 2>/dev/null | awk '/\"LastExitStatus\"/ {print $3}' | tr -d ';' || true)
  if [ -z "$exit_status" ]; then
    # Try alternate format: launchctl list output for the label
    exit_status=$(launchctl list | grep "$label" | awk '{print $2}' || true)
  fi

  # Decode raw POSIX wait() value: actual_exit = raw >> 8
  if [[ "$exit_status" =~ ^[0-9]+$ ]] && [ "$exit_status" -gt 255 ]; then
    decoded_exit=$(( exit_status >> 8 ))
  else
    decoded_exit="$exit_status"
  fi

  if [ "$decoded_exit" = "126" ]; then
    agent_errors+="| \`$agent_name\` | Exit 126 (permission/PATH issue) | FAIL |\n"
    agent_fail=$((agent_fail + 1))
  elif [ -n "$decoded_exit" ] && [ "$decoded_exit" != "0" ] && [ "$decoded_exit" != "-" ]; then
    agent_errors+="| \`$agent_name\` | Last exit code: $decoded_exit | WARN |\n"
    total_warn=$((total_warn + 1))
    agent_pass=$((agent_pass + 1))
  else
    agent_pass=$((agent_pass + 1))
  fi
done

# Check for recent runs in DB
db_path="$REPO_DIR/dashboard/data/sk-dashboard.db"
if [ -f "$db_path" ]; then
  for agent_name in maintain harvest; do
    last_run=$(python3 -c "
import sqlite3, sys
conn = sqlite3.connect('$db_path')
cur = conn.execute(
    'SELECT finished_at FROM agent_runs WHERE agent_name=? AND project=? ORDER BY id DESC LIMIT 1',
    ('$agent_name', '$PROJECT_NAME'))
row = cur.fetchone()
print(row[0] if row else '')
conn.close()
" 2>/dev/null || true)
    if [ -z "$last_run" ]; then
      agent_errors+="| \`$agent_name\` | No runs recorded in DB | WARN |\n"
      total_warn=$((total_warn + 1))
    fi
  done
else
  agent_errors+="| (all) | Dashboard DB not found at \`$db_path\` | WARN |\n"
  total_warn=$((total_warn + 1))
fi

agent_total=$((agent_pass + agent_fail))

cat >> "$REPORT" <<EOF
**Result:** $agent_pass/$agent_total agents healthy, $agent_fail failed

EOF

if [ -n "$agent_errors" ]; then
  cat >> "$REPORT" <<EOF
| Agent | Issue | Severity |
|-------|-------|----------|
$(echo -e "$agent_errors")
EOF
fi

echo "" >> "$REPORT"

total_pass=$((total_pass + agent_pass))
total_fail=$((total_fail + agent_fail))

# ═══════════════════════════════════════════════════════════════
# Summary
# ═══════════════════════════════════════════════════════════════

end_epoch=$(date +%s)
elapsed=$((end_epoch - start_epoch))

if [ "$total_fail" -eq 0 ]; then
  status="ALL PASSED"
else
  status="$total_fail FAILURE(S)"
fi

cat >> "$REPORT" <<EOF
---

## Summary

| Metric | Value |
|--------|-------|
| Status | **$status** |
| Passed | $total_pass |
| Failed | $total_fail |
| Warnings | $total_warn |
| Duration | ${elapsed}s |
EOF

# Record run to dashboard DB
_sk_exec_record_run "$PROJECT_NAME" "tester" "$start_epoch" "$end_epoch" \
  "$total_fail" "" "" "" "" "" ""

echo "[$(date '+%Y-%m-%d %H:%M')] Test complete: $status ($total_pass pass, $total_fail fail, $total_warn warn). Report: $REPORT"

# ─── Auto-heal: run doctor if agent health checks found failures ───
if [ "$agent_fail" -gt 0 ] && [ -x "$REPO_DIR/bin/sk-agent-doctor" ]; then
  echo "[$(date '+%Y-%m-%d %H:%M')] Agent failures detected — running sk-agent-doctor..."
  "$REPO_DIR/bin/sk-agent-doctor" 2>&1 | tee -a "$REPORT_DIR/doctor-${TODAY}.log" || true
fi

# Exit with failure count (0 = success)
[ "$total_fail" -gt 0 ] && exit 1
exit 0
