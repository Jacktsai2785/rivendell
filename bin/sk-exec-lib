#!/usr/bin/env bash
# sk-exec-lib — Unified Agent Execution Engine
# Source this file to get sk_exec() and sk_cost_append()
#
# Usage:
#   source "$(dirname "$0")/sk-exec-lib"
#   SK_EXEC_PROJECT_DIR="/path/to/project" sk_exec "do something"

# Guard against double-sourcing
[ -n "${_SK_EXEC_LIB_LOADED:-}" ] && return 0
_SK_EXEC_LIB_LOADED=1

# Resolve repo dir (same as bin/sk)
SK_EXEC_REPO_DIR="${SK_EXEC_REPO_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
SK_EXEC_PARSER="${SK_EXEC_REPO_DIR}/scripts/parse-agent-log.py"

# ─── sk_exec() ───────────────────────────────────────────────────────
# Run claude -p with structured logging and cost tracking.
#
# Arguments:
#   $1 — prompt text
#
# Configuration via SK_EXEC_* env vars:
#   SK_EXEC_PROJECT_DIR   — target directory (default: pwd)
#   SK_EXEC_MODEL         — model name
#   SK_EXEC_BUDGET        — max USD
#   SK_EXEC_TOOLS         — allowed tools (space-separated)
#   SK_EXEC_PERM_MODE     — default/auto/bypassPermissions (default: "default")
#   SK_EXEC_SESSION_NAME  — for resume (auto-generated if empty)
#   SK_EXEC_LOG_PREFIX    — log filename prefix (default: "run")
#   SK_EXEC_STRUCTURED    — "1" for stream-json + parser (default: "1")
#   SK_EXEC_OUTPUT_DIR    — log destination (default: $SK_EXEC_REPO_DIR/logs)
#   SK_EXEC_CONTEXT       — "1" to inject project CLAUDE.md into prompt
#   SK_EXEC_QUIET         — "1" to suppress banner
#   SK_EXEC_DRY_RUN       — "1" to print command without executing
#
# Result vars set after execution:
#   SK_EXEC_RESULT_LOG        — path to plain log file
#   SK_EXEC_RESULT_STRUCTURED — path to structured JSONL (if enabled)
#   SK_EXEC_RESULT_EXIT       — exit code
#   SK_EXEC_RESULT_ELAPSED    — elapsed seconds
#   SK_EXEC_RESULT_SESSION    — session name used

sk_exec() {
  local prompt="${1:?sk_exec: prompt required}"

  # Read config from env with defaults
  local project_dir="${SK_EXEC_PROJECT_DIR:-$(pwd)}"
  local model="${SK_EXEC_MODEL:-}"
  local budget="${SK_EXEC_BUDGET:-}"
  local tools="${SK_EXEC_TOOLS:-Read Write Edit Bash Glob Grep Agent WebFetch WebSearch}"
  local perm_mode="${SK_EXEC_PERM_MODE:-default}"
  local log_prefix="${SK_EXEC_LOG_PREFIX:-run}"
  local structured="${SK_EXEC_STRUCTURED:-1}"
  local output_dir="${SK_EXEC_OUTPUT_DIR:-${SK_EXEC_REPO_DIR}/logs}"
  local inject_context="${SK_EXEC_CONTEXT:-0}"
  local quiet="${SK_EXEC_QUIET:-0}"
  local dry_run="${SK_EXEC_DRY_RUN:-0}"

  # Resolve project directory
  project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || {
    echo "sk_exec: directory not found: $project_dir" >&2
    return 1
  }

  # Derive project short name from directory
  local project_name
  project_name="$(basename "$project_dir")"

  # Session name
  local session_name="${SK_EXEC_SESSION_NAME:-sk-${log_prefix}-${project_name}-$(date '+%H%M%S')}"

  # Prepare log paths
  mkdir -p "$output_dir"
  local timestamp
  timestamp="$(date '+%Y%m%d-%H%M%S')"
  local log_file="${output_dir}/${log_prefix}-${timestamp}.log"
  local structured_log=""
  if [ "$structured" = "1" ]; then
    structured_log="${output_dir}/${log_prefix}-${timestamp}.structured.jsonl"
  fi

  # Inject CLAUDE.md context if requested
  if [ "$inject_context" = "1" ]; then
    local claude_md="${project_dir}/.claude/CLAUDE.md"
    if [ -f "$claude_md" ]; then
      local ctx
      ctx="$(cat "$claude_md")"
      prompt="# Project Context (from .claude/CLAUDE.md)

${ctx}

---

${prompt}"
    fi
  fi

  # Build claude command
  local cmd=("claude" "-p" "--permission-mode" "$perm_mode")

  [ -n "$model" ] && cmd+=("--model" "$model")
  [ -n "$budget" ] && cmd+=("--max-budget-usd" "$budget")
  cmd+=("--allowedTools" "$tools")
  cmd+=("--name" "$session_name")

  if [ "$structured" = "1" ]; then
    cmd+=("--output-format" "stream-json")
  fi

  cmd+=("$prompt")

  # Banner
  if [ "$quiet" != "1" ]; then
    echo -e "\033[0;36m╭─────────────────────────────────────────╮\033[0m"
    echo -e "\033[0;36m│         sk exec — Agent Engine           │\033[0m"
    echo -e "\033[0;36m╰─────────────────────────────────────────╯\033[0m"
    local task_preview="${prompt:0:80}"
    [ ${#prompt} -gt 80 ] && task_preview="${task_preview}..."
    echo -e "  \033[0;32mTask:\033[0m    $task_preview"
    echo -e "  \033[0;32mDir:\033[0m     $project_dir"
    echo -e "  \033[0;32mMode:\033[0m    $perm_mode"
    [ -n "$model" ] && echo -e "  \033[0;32mModel:\033[0m   $model"
    [ -n "$budget" ] && echo -e "  \033[0;32mBudget:\033[0m  \$$budget"
    echo -e "  \033[0;32mLog:\033[0m     $log_file"
    echo -e "  \033[0;32mSession:\033[0m $session_name"
    [ "$structured" = "1" ] && echo -e "  \033[0;32mJSON:\033[0m    $structured_log"
    echo ""
  fi

  # Dry run
  if [ "$dry_run" = "1" ]; then
    echo -e "\033[0;33m[dry-run]\033[0m Would execute:"
    echo "  cd $project_dir && ${cmd[*]}"
    # Set result vars for dry-run
    SK_EXEC_RESULT_LOG="$log_file"
    SK_EXEC_RESULT_STRUCTURED="$structured_log"
    SK_EXEC_RESULT_EXIT=0
    SK_EXEC_RESULT_ELAPSED=0
    SK_EXEC_RESULT_SESSION="$session_name"
    return 0
  fi

  # Execute
  [ "$quiet" != "1" ] && echo -e "\033[0;36mRunning...\033[0m" && echo ""

  local start_time exit_code
  start_time=$(date +%s)

  if [ "$structured" = "1" ] && [ -f "$SK_EXEC_PARSER" ]; then
    # Stream-json mode: pipe through parser
    (cd "$project_dir" && "${cmd[@]}") 2>>"$log_file" \
      | python3 -u "$SK_EXEC_PARSER" --output "$structured_log" \
      | tee -a "$log_file"
    exit_code=${PIPESTATUS[0]}
  else
    # Plain mode: tee to log
    (cd "$project_dir" && "${cmd[@]}") 2>&1 | tee "$log_file"
    exit_code=${PIPESTATUS[0]}
  fi

  local end_time elapsed
  end_time=$(date +%s)
  elapsed=$((end_time - start_time))

  # Set result vars
  SK_EXEC_RESULT_LOG="$log_file"
  SK_EXEC_RESULT_STRUCTURED="$structured_log"
  SK_EXEC_RESULT_EXIT="$exit_code"
  SK_EXEC_RESULT_ELAPSED="$elapsed"
  SK_EXEC_RESULT_SESSION="$session_name"

  # Summary
  if [ "$quiet" != "1" ]; then
    echo ""
    echo -e "\033[0;36m─────────────────────────────────────────\033[0m"
    if [ "$exit_code" -eq 0 ]; then
      echo -e "\033[0;32m✓ Done\033[0m in ${elapsed}s — log: $log_file"
    else
      echo -e "\033[0;31m✗ Failed\033[0m (exit $exit_code) in ${elapsed}s — log: $log_file"
    fi
    echo -e "  Resume: \033[0;33mclaude --resume '$session_name'\033[0m"
  fi

  # Auto-append cost if structured log exists
  if [ "$structured" = "1" ] && [ -f "$structured_log" ]; then
    sk_cost_append "$project_name" "$log_prefix" "$session_name" "$structured_log"
  fi

  # Auto-commit agent output if enabled and run succeeded
  local commit_sha_result=""
  local files_changed_result=""
  local qa_passed_result=""
  local branch_name_result=""
  local pr_url_result=""

  if [ "$exit_code" -eq 0 ] && [ "${SK_EXEC_AUTO_COMMIT:-0}" = "1" ]; then
    local merge_strategy="${SK_EXEC_MERGE_STRATEGY:-auto}"
    if [ "$merge_strategy" = "pr" ]; then
      sk_exec_branch_workflow "$project_dir" "$log_prefix" "$timestamp"
    else
      sk_exec_post_git "$project_dir" "$log_prefix" "$timestamp"
    fi
    # Capture post-git results
    commit_sha_result="${SK_EXEC_POST_COMMIT_SHA:-}"
    files_changed_result="${SK_EXEC_POST_FILES_CHANGED:-}"
    qa_passed_result="${SK_EXEC_POST_QA_PASSED:-}"
    branch_name_result="${SK_EXEC_POST_BRANCH_NAME:-}"
    pr_url_result="${SK_EXEC_POST_PR_URL:-}"
  fi

  # Record run to dashboard DB
  _sk_exec_record_run "$project_name" "$log_prefix" "$start_time" "$end_time" \
    "$exit_code" "$structured_log" "$commit_sha_result" "$files_changed_result" \
    "$qa_passed_result" "$branch_name_result" "$pr_url_result"

  return "$exit_code"
}

# ─── sk_cost_append() ────────────────────────────────────────────────
# Read the result line from a structured JSONL log and append to cost ledger.
#
# Arguments:
#   $1 — project name
#   $2 — run type (e.g. "run", "research-agent")
#   $3 — session name
#   $4 — structured JSONL file path

sk_cost_append() {
  local project="$1" run_type="$2" session="$3" structured_file="$4"
  local ledger_dir="${SK_EXEC_REPO_DIR}/data"
  local ledger="${ledger_dir}/cost-ledger.jsonl"

  [ ! -f "$structured_file" ] && return 0

  mkdir -p "$ledger_dir"

  # Extract the last "result" line from structured log
  python3 -c "
import json, sys
from datetime import datetime

structured_file = '$structured_file'
project = '$project'
run_type = '$run_type'
session = '$session'
ledger = '$ledger'

result = None
try:
    with open(structured_file) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get('type') == 'result':
                    result = obj
            except:
                continue
except:
    sys.exit(0)

if not result:
    sys.exit(0)

now = datetime.now()
entry = {
    'date': now.strftime('%Y-%m-%d'),
    'time': now.strftime('%H:%M:%S'),
    'project': project,
    'run_type': run_type,
    'session': session,
    'model': result.get('model', 'unknown'),
    'input_tokens': result.get('input_tokens', 0),
    'output_tokens': result.get('output_tokens', 0),
    'cost_usd': result.get('cost_usd', 0),
}

with open(ledger, 'a') as f:
    f.write(json.dumps(entry, ensure_ascii=False) + '\n')
" 2>/dev/null || true
}

# ─── sk_exec_pre_commit_check() ──────────────────────────────────────
# Run QA checks before committing. Returns 0 if OK, 1 if failed.
#
# Arguments:
#   $1 — project directory
#
# Configuration:
#   SK_EXEC_QA_CHECK — "off" (default), "auto", or path to script

sk_exec_pre_commit_check() {
  local project_dir="$1"
  local qa_check="${SK_EXEC_QA_CHECK:-off}"

  [ "$qa_check" = "off" ] && return 0

  if [ "$qa_check" = "auto" ]; then
    # Auto-detect test framework
    if [ -f "$project_dir/pyproject.toml" ] || [ -f "$project_dir/pytest.ini" ] || [ -f "$project_dir/setup.cfg" ]; then
      if command -v pytest &>/dev/null; then
        echo -e "\033[0;36m[qa-gate]\033[0m Running pytest..."
        (cd "$project_dir" && pytest --tb=short -q 2>&1) && return 0
        return 1
      fi
    elif [ -f "$project_dir/vitest.config.ts" ] || [ -f "$project_dir/vitest.config.js" ]; then
      if command -v npx &>/dev/null; then
        echo -e "\033[0;36m[qa-gate]\033[0m Running vitest..."
        (cd "$project_dir" && npx vitest run 2>&1) && return 0
        return 1
      fi
    elif [ -f "$project_dir/Package.swift" ]; then
      echo -e "\033[0;36m[qa-gate]\033[0m Running swift test..."
      (cd "$project_dir" && swift test 2>&1) && return 0
      return 1
    fi
    # No test framework detected — pass
    return 0
  fi

  # Custom script path
  if [ -x "$qa_check" ]; then
    echo -e "\033[0;36m[qa-gate]\033[0m Running $qa_check..."
    (cd "$project_dir" && "$qa_check" 2>&1) && return 0
    return 1
  elif [ -f "$qa_check" ]; then
    echo -e "\033[0;36m[qa-gate]\033[0m Running $qa_check..."
    (cd "$project_dir" && bash "$qa_check" 2>&1) && return 0
    return 1
  fi

  echo -e "\033[0;33m[qa-gate]\033[0m QA script not found: $qa_check" >&2
  return 1
}

# ─── sk_exec_path_filter() ───────────────────────────────────────────
# Filter staged files by allowed/forbidden path patterns.
# Unstages files that don't pass the filter.
#
# Arguments:
#   $1 — project directory
#
# Configuration:
#   SK_EXEC_ALLOWED_PATHS   — colon-separated globs (empty = all allowed)
#   SK_EXEC_FORBIDDEN_PATHS — colon-separated globs (default: ".env*:*.db:.claude/**")
#   SK_EXEC_MAX_FILES       — max changed files (0 = unlimited)

sk_exec_path_filter() {
  local project_dir="$1"
  local allowed="${SK_EXEC_ALLOWED_PATHS:-}"
  local forbidden="${SK_EXEC_FORBIDDEN_PATHS:-.env*:*.db:.claude/**}"
  local max_files="${SK_EXEC_MAX_FILES:-0}"

  cd "$project_dir"

  # Get list of staged files
  local staged_files
  staged_files="$(git diff --cached --name-only 2>/dev/null)"
  [ -z "$staged_files" ] && return 0

  local rejected=()
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    local dominated=false

    # Check forbidden paths
    if [ -n "$forbidden" ]; then
      IFS=':' read -ra fpats <<< "$forbidden"
      for pat in "${fpats[@]}"; do
        # Use bash extended globbing via python for reliability
        if python3 -c "
import fnmatch, sys
sys.exit(0 if fnmatch.fnmatch('$file', '$pat') else 1)
" 2>/dev/null; then
          dominated=true
          break
        fi
      done
    fi

    # Check allowed paths (if specified, file must match at least one)
    if [ "$dominated" = false ] && [ -n "$allowed" ]; then
      local in_allowed=false
      IFS=':' read -ra apats <<< "$allowed"
      for pat in "${apats[@]}"; do
        if python3 -c "
import fnmatch, sys
sys.exit(0 if fnmatch.fnmatch('$file', '$pat') else 1)
" 2>/dev/null; then
          in_allowed=true
          break
        fi
      done
      [ "$in_allowed" = false ] && dominated=true
    fi

    if [ "$dominated" = true ]; then
      rejected+=("$file")
      git reset HEAD -- "$file" &>/dev/null
    fi
  done <<< "$staged_files"

  if [ ${#rejected[@]} -gt 0 ]; then
    echo -e "\033[0;33m[path-filter]\033[0m Unstaged ${#rejected[@]} file(s) outside allowed paths:"
    for f in "${rejected[@]}"; do
      echo "  - $f"
    done
  fi

  # Check max files
  if [ "$max_files" -gt 0 ]; then
    local remaining
    remaining="$(git diff --cached --name-only | wc -l | tr -d ' ')"
    if [ "$remaining" -gt "$max_files" ]; then
      echo -e "\033[0;31m[path-filter]\033[0m Too many files changed ($remaining > $max_files). Unstaging all." >&2
      git reset HEAD -- . &>/dev/null
      return 1
    fi
  fi

  return 0
}

# ─── sk_exec_post_git() ──────────────────────────────────────────────
# Auto-commit agent output files after a successful run.
# Only stages files matching SK_EXEC_COMMIT_SCOPE patterns.
#
# Arguments:
#   $1 — project directory
#   $2 — agent name (for commit message)
#   $3 — timestamp
#
# Configuration:
#   SK_EXEC_COMMIT_SCOPE — space-separated glob patterns to stage
#   SK_EXEC_AUTO_PUSH    — "1" to push after commit
#   SK_EXEC_GIT_SIGNOFF  — agent signature (default: "agent")

sk_exec_post_git() {
  local project_dir="$1"
  local agent_name="$2"
  local timestamp="$3"
  local commit_scope="${SK_EXEC_COMMIT_SCOPE:-reports/*.md reports/*.html data/*.jsonl}"
  local auto_push="${SK_EXEC_AUTO_PUSH:-0}"
  local signoff="${SK_EXEC_GIT_SIGNOFF:-agent}"
  local dry_run="${SK_EXEC_DRY_RUN:-0}"
  local quiet="${SK_EXEC_QUIET:-0}"
  local structured_log="${SK_EXEC_RESULT_STRUCTURED:-}"

  cd "$project_dir"

  # Check for any changes
  if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    [ "$quiet" != "1" ] && echo -e "\033[0;36m[post-git]\033[0m No changes to commit."
    return 0
  fi

  # Stage files matching commit scope
  local staged_count=0
  for pattern in $commit_scope; do
    # Use git add with glob — only matches existing files
    git add $pattern 2>/dev/null && staged_count=$((staged_count + 1)) || true
  done

  # Check if anything was staged
  if git diff --cached --quiet; then
    [ "$quiet" != "1" ] && echo -e "\033[0;36m[post-git]\033[0m No matching files to commit (scope: $commit_scope)."
    return 0
  fi

  # Apply path filters (allowed/forbidden)
  sk_exec_path_filter "$project_dir" || {
    _sk_exec_log_event "$structured_log" "path_filter_rejected" "$agent_name"
    return 1
  }

  # Re-check after filtering
  if git diff --cached --quiet; then
    [ "$quiet" != "1" ] && echo -e "\033[0;36m[post-git]\033[0m All staged files were filtered out."
    return 0
  fi

  # QA gate
  sk_exec_pre_commit_check "$project_dir" || {
    echo -e "\033[0;31m[post-git]\033[0m QA gate failed — unstaging and skipping commit." >&2
    git reset HEAD -- . &>/dev/null
    SK_EXEC_POST_QA_PASSED="0"
    _sk_exec_log_event "$structured_log" "qa_gate_failed" "$agent_name"
    return 1
  }

  # Build commit message
  local run_date
  run_date="$(echo "$timestamp" | sed 's/\([0-9]\{8\}\).*/\1/' | sed 's/\(....\)\(..\)\(..\)/\1-\2-\3/')"
  local commit_msg
  commit_msg="$(cat <<EOF
chore(agent): ${agent_name} run ${run_date}

Auto-committed by sk_exec [${signoff}]
Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
EOF
)"

  # Dry run
  if [ "$dry_run" = "1" ]; then
    echo -e "\033[0;33m[post-git dry-run]\033[0m Would commit:"
    git diff --cached --stat
    echo "  Message: chore(agent): ${agent_name} run ${run_date}"
    [ "$auto_push" = "1" ] && echo "  Would push to origin"
    return 0
  fi

  # Commit
  git commit -m "$commit_msg" --quiet
  local commit_sha
  commit_sha="$(git rev-parse --short HEAD)"
  echo -e "\033[0;32m[post-git]\033[0m Committed: $commit_sha"
  git diff --stat HEAD~1 2>/dev/null | sed 's/^/  /'

  # Export result vars for _sk_exec_record_run
  SK_EXEC_POST_COMMIT_SHA="$commit_sha"
  SK_EXEC_POST_FILES_CHANGED="$(git diff --name-only HEAD~1 2>/dev/null | wc -l | tr -d ' ')"
  SK_EXEC_POST_QA_PASSED="1"

  # Log commit SHA to structured log
  _sk_exec_log_event "$structured_log" "auto_commit" "$commit_sha"

  # Push
  if [ "$auto_push" = "1" ]; then
    echo -e "\033[0;36m[post-git]\033[0m Pushing..."
    if git push 2>&1; then
      echo -e "\033[0;32m[post-git]\033[0m Pushed successfully."
      _sk_exec_log_event "$structured_log" "auto_push" "ok"
    else
      echo -e "\033[0;31m[post-git]\033[0m Push failed." >&2
      _sk_exec_log_event "$structured_log" "auto_push" "failed"
    fi
  fi

  return 0
}

# ─── sk_exec_branch_workflow() ────────────────────────────────────────
# Create a branch, commit changes, push, and optionally create a PR.
# Used for "pr" merge strategy agents (e.g. developer role).
#
# Arguments:
#   $1 — project directory
#   $2 — agent name
#   $3 — timestamp
#
# Configuration:
#   SK_EXEC_BRANCH_PREFIX  — branch prefix (default: "agent/")
#   SK_EXEC_CREATE_PR      — "1" to create PR via gh
#   SK_EXEC_COMMIT_SCOPE   — glob patterns to stage
#   SK_EXEC_AUTO_PUSH      — "1" to push (required for PR)

sk_exec_branch_workflow() {
  local project_dir="$1"
  local agent_name="$2"
  local timestamp="$3"
  local branch_prefix="${SK_EXEC_BRANCH_PREFIX:-agent/}"
  local create_pr="${SK_EXEC_CREATE_PR:-0}"
  local commit_scope="${SK_EXEC_COMMIT_SCOPE:-reports/*.md reports/*.html data/*.jsonl}"
  local dry_run="${SK_EXEC_DRY_RUN:-0}"
  local quiet="${SK_EXEC_QUIET:-0}"
  local structured_log="${SK_EXEC_RESULT_STRUCTURED:-}"

  cd "$project_dir"

  # Check for changes
  if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    [ "$quiet" != "1" ] && echo -e "\033[0;36m[branch]\033[0m No changes to commit."
    return 0
  fi

  # Generate branch name
  local run_date
  run_date="$(echo "$timestamp" | sed 's/\([0-9]\{8\}\).*/\1/' | sed 's/\(....\)\(..\)\(..\)/\1-\2-\3/')"
  local short_sha
  short_sha="$(git rev-parse --short HEAD)"
  local branch_name="${branch_prefix}${agent_name}/${run_date}-${short_sha}"

  if [ "$dry_run" = "1" ]; then
    echo -e "\033[0;33m[branch dry-run]\033[0m Would create branch: $branch_name"
    return 0
  fi

  # Create and switch to branch
  local original_branch
  original_branch="$(git rev-parse --abbrev-ref HEAD)"
  git checkout -b "$branch_name" --quiet

  # Stage files matching commit scope
  for pattern in $commit_scope; do
    git add $pattern 2>/dev/null || true
  done

  if git diff --cached --quiet; then
    echo -e "\033[0;36m[branch]\033[0m No matching files to commit."
    git checkout "$original_branch" --quiet
    git branch -D "$branch_name" --quiet 2>/dev/null
    return 0
  fi

  # Apply path filters
  sk_exec_path_filter "$project_dir" || {
    git reset HEAD -- . &>/dev/null
    git checkout "$original_branch" --quiet
    git branch -D "$branch_name" --quiet 2>/dev/null
    _sk_exec_log_event "$structured_log" "path_filter_rejected" "$agent_name"
    return 1
  }

  if git diff --cached --quiet; then
    git checkout "$original_branch" --quiet
    git branch -D "$branch_name" --quiet 2>/dev/null
    return 0
  fi

  # QA gate
  sk_exec_pre_commit_check "$project_dir" || {
    echo -e "\033[0;31m[branch]\033[0m QA gate failed — aborting branch." >&2
    git reset HEAD -- . &>/dev/null
    git checkout "$original_branch" --quiet
    git branch -D "$branch_name" --quiet 2>/dev/null
    _sk_exec_log_event "$structured_log" "qa_gate_failed" "$agent_name"
    return 1
  }

  # Commit
  local commit_msg
  commit_msg="$(cat <<EOF
feat(agent): ${agent_name} run ${run_date}

Auto-committed by sk_exec (branch workflow)
Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
EOF
)"
  git commit -m "$commit_msg" --quiet
  local commit_sha
  commit_sha="$(git rev-parse --short HEAD)"
  echo -e "\033[0;32m[branch]\033[0m Committed $commit_sha on $branch_name"

  # Export result vars for _sk_exec_record_run
  SK_EXEC_POST_COMMIT_SHA="$commit_sha"
  SK_EXEC_POST_FILES_CHANGED="$(git diff --name-only HEAD~1 2>/dev/null | wc -l | tr -d ' ')"
  SK_EXEC_POST_QA_PASSED="1"
  SK_EXEC_POST_BRANCH_NAME="$branch_name"

  _sk_exec_log_event "$structured_log" "branch_commit" "$commit_sha on $branch_name"

  # Push
  if [ "${SK_EXEC_AUTO_PUSH:-0}" = "1" ]; then
    echo -e "\033[0;36m[branch]\033[0m Pushing $branch_name..."
    git push -u origin "$branch_name" 2>&1 || {
      echo -e "\033[0;31m[branch]\033[0m Push failed." >&2
      git checkout "$original_branch" --quiet
      return 1
    }
    _sk_exec_log_event "$structured_log" "branch_push" "$branch_name"

    # Create PR
    if [ "$create_pr" = "1" ] && command -v gh &>/dev/null; then
      echo -e "\033[0;36m[branch]\033[0m Creating PR..."
      local pr_url
      pr_url="$(gh pr create \
        --title "Agent: ${agent_name} ${run_date}" \
        --body "Auto-generated by ${agent_name} agent via sk_exec branch workflow.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>" \
        --label "agent-generated" 2>&1)" || true
      if [ -n "$pr_url" ]; then
        echo -e "\033[0;32m[branch]\033[0m PR created: $pr_url"
        SK_EXEC_POST_PR_URL="$pr_url"
        _sk_exec_log_event "$structured_log" "pr_created" "$pr_url"
      fi
    fi
  fi

  # Return to original branch
  git checkout "$original_branch" --quiet
  return 0
}

# ─── _sk_exec_log_event() ────────────────────────────────────────────
# Append event to structured JSONL log (internal helper).
#
# Arguments:
#   $1 — structured log path (empty = skip)
#   $2 — event type
#   $3 — event detail

# ─── _sk_exec_record_run() ─────────────────────────────────────────
# Write a run record to the dashboard SQLite database.
#
# Arguments:
#   $1  — project name
#   $2  — agent name
#   $3  — start_time (epoch)
#   $4  — end_time (epoch)
#   $5  — exit code
#   $6  — structured log path (to extract tokens/cost)
#   $7  — commit SHA (optional)
#   $8  — files changed count (optional)
#   $9  — qa passed (0/1, optional)
#   $10 — branch name (optional)
#   $11 — PR URL (optional)

_sk_exec_record_run() {
  local project="$1" agent_name="$2"
  local start_epoch="$3" end_epoch="$4"
  local run_exit_code="$5" structured_file="$6"
  local commit_sha="${7:-}" files_changed="${8:-}"
  local qa_passed="${9:-}" branch_name="${10:-}" pr_url="${11:-}"

  local db_path="${SK_EXEC_REPO_DIR}/dashboard/data/sk-dashboard.db"

  # Ensure data dir exists
  mkdir -p "$(dirname "$db_path")"

  python3 -c "
import sqlite3, json, sys
from datetime import datetime

db_path = '$db_path'
project = '$project'
agent_name = '$agent_name'
start_epoch = int('$start_epoch') if '$start_epoch' else 0
end_epoch = int('$end_epoch') if '$end_epoch' else 0
exit_code = int('$run_exit_code') if '$run_exit_code' else None
structured_file = '$structured_file'
commit_sha = '$commit_sha' or None
files_changed = int('$files_changed') if '$files_changed' else None
qa_passed = int('$qa_passed') if '$qa_passed' else None
branch_name = '$branch_name' or None
pr_url = '$pr_url' or None

started_at = datetime.fromtimestamp(start_epoch).isoformat() if start_epoch else None
finished_at = datetime.fromtimestamp(end_epoch).isoformat() if end_epoch else None

# Extract tokens/cost from structured log
tokens_used = None
cost_usd = None
if structured_file:
    try:
        with open(structured_file) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                    if obj.get('type') == 'result':
                        tokens_used = obj.get('input_tokens', 0) + obj.get('output_tokens', 0)
                        cost_usd = obj.get('cost_usd', 0)
                except:
                    continue
    except:
        pass

conn = sqlite3.connect(db_path)
conn.execute('''CREATE TABLE IF NOT EXISTS agent_runs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    agent_name TEXT NOT NULL, project TEXT NOT NULL,
    started_at TEXT, finished_at TEXT, exit_code INTEGER,
    log_path TEXT, report_path TEXT, tokens_used INTEGER, cost_usd REAL,
    commit_sha TEXT, files_changed INTEGER, qa_passed INTEGER,
    branch_name TEXT, pr_url TEXT
)''')
conn.execute('''INSERT INTO agent_runs
    (agent_name, project, started_at, finished_at, exit_code,
     tokens_used, cost_usd, commit_sha, files_changed, qa_passed, branch_name, pr_url)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)''',
    (agent_name, project, started_at, finished_at, exit_code,
     tokens_used, cost_usd, commit_sha, files_changed, qa_passed, branch_name, pr_url))
conn.commit()
conn.close()
" 2>/dev/null || true
}

_sk_exec_log_event() {
  local log_file="$1"
  local event_type="$2"
  local detail="$3"
  [ -z "$log_file" ] && return 0
  [ ! -f "$log_file" ] && return 0
  python3 -c "
import json
from datetime import datetime
entry = {
    'type': '$event_type',
    'detail': '''$detail''',
    'ts': datetime.now().isoformat()
}
with open('$log_file', 'a') as f:
    f.write(json.dumps(entry) + '\n')
" 2>/dev/null || true
}
