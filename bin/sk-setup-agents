#!/usr/bin/env bash
# Bootstrap script — generates and loads launchd plists from agents.conf.
# Run once on a new machine (or after changing agents.conf):
#   ./bin/sk-setup-agents
#
# What it does:
#   1. Compiles sk-agent-run binary (sets REPO_DIR env to bypass TCC getcwd)
#   2. Detects python3/conda/npm paths → builds PATH
#   3. Reads agents/agents.conf → generates plist per agent
#      (launchd logs go to ~/Library/Logs/sk-agent/ to avoid TCC on ~/Documents/)
#   4. Loads all plists into launchd
#
# Options:
#   --dry-run   Print generated plists without installing
#   --unload    Unload all managed agents
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONF="$REPO_DIR/agents/agents.conf"
LAUNCH_DIR="$HOME/Library/LaunchAgents"
SK_AGENT_RUN="$HOME/.local/bin/sk-agent-run"
PROJECTS_DIR="$HOME/Documents/Projects"
DRY_RUN=false
UNLOAD_ONLY=false

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --unload) UNLOAD_ONLY=true ;;
  esac
done

# ─── Detect PATH components ───
detect_path() {
  local parts="/usr/local/bin:/usr/bin:/bin"

  # Homebrew
  if [ -d "/opt/homebrew/bin" ]; then
    parts="/opt/homebrew/bin:$parts"
  fi

  # Conda (search common locations)
  for conda_bin in \
    "$HOME/miniconda3/bin" \
    "$HOME/anaconda3/bin" \
    "/opt/homebrew/Caskroom/miniconda/base/bin" \
    "$HOME/.conda/bin"; do
    if [ -d "$conda_bin" ]; then
      parts="$conda_bin:$parts"
      break
    fi
  done

  # npm global
  local npm_bin
  npm_bin="$(npm config get prefix 2>/dev/null)/bin" || true
  if [ -d "$npm_bin" ]; then
    parts="$parts:$npm_bin"
  fi

  # ~/.local/bin
  parts="$parts:$HOME/.local/bin"

  echo "$parts"
}

AGENT_PATH="$(detect_path)"
echo "Detected PATH: $AGENT_PATH"
echo ""

# ─── Compile & install sk-agent-run ───
if ! $DRY_RUN && ! $UNLOAD_ONLY; then
  echo "Compiling sk-agent-run..."
  mkdir -p "$(dirname "$SK_AGENT_RUN")"
  cc -O2 -o "$SK_AGENT_RUN" "$REPO_DIR/agents/sk-agent-run.c"
  echo "Installed: $SK_AGENT_RUN"
  echo ""
fi

# ─── Unload mode ───
if $UNLOAD_ONLY; then
  echo "Unloading all managed agents..."
  grep -v '^\s*#' "$CONF" | grep -v '^\s*$' | while IFS='|' read -r label _rest; do
    label="$(echo "$label" | xargs)"
    plist="$LAUNCH_DIR/${label}.plist"
    if [ -f "$plist" ]; then
      launchctl unload "$plist" 2>/dev/null && echo "  Unloaded: $label" || true
    fi
  done
  exit 0
fi

# ─── Helper: generate <StartCalendarInterval> ───
gen_calendar() {
  local val="$1"
  local weekday="" hour="" minute=""

  IFS=':' read -ra parts <<< "$val"
  if [ ${#parts[@]} -eq 3 ]; then
    weekday="${parts[0]}"
    hour="${parts[1]}"
    minute="${parts[2]}"
  elif [ ${#parts[@]} -eq 2 ]; then
    hour="${parts[0]}"
    minute="${parts[1]}"
  fi

  echo "    <key>StartCalendarInterval</key>"
  echo "    <dict>"
  [ -n "$weekday" ] && echo "        <key>Weekday</key><integer>$weekday</integer>"
  echo "        <key>Hour</key><integer>$((10#$hour))</integer>"
  echo "        <key>Minute</key><integer>$((10#$minute))</integer>"
  echo "    </dict>"
}

gen_calendar_multi() {
  local val="$1"
  echo "    <key>StartCalendarInterval</key>"
  echo "    <array>"
  IFS=',' read -ra entries <<< "$val"
  for entry in "${entries[@]}"; do
    entry="$(echo "$entry" | xargs)"
    IFS=':' read -ra parts <<< "$entry"
    echo "        <dict>"
    [ ${#parts[@]} -eq 3 ] && echo "            <key>Weekday</key><integer>${parts[0]}</integer>"
    local h="${parts[$((${#parts[@]}-2))]}"
    local m="${parts[$((${#parts[@]}-1))]}"
    echo "            <key>Hour</key><integer>$((10#$h))</integer>"
    echo "            <key>Minute</key><integer>$((10#$m))</integer>"
    echo "        </dict>"
  done
  echo "    </array>"
}

# ─── Generate plists ───
mkdir -p "$LAUNCH_DIR"

grep -v '^\s*#' "$CONF" | grep -v '^\s*$' | while IFS='|' read -r label project_rel script sched_type sched_val log_dir_rel extra_args; do
  # Trim whitespace
  label="$(echo "$label" | xargs)"
  project_rel="$(echo "$project_rel" | xargs)"
  script="$(echo "$script" | xargs)"
  sched_type="$(echo "$sched_type" | xargs)"
  sched_val="$(echo "$sched_val" | xargs)"
  log_dir_rel="$(echo "$log_dir_rel" | xargs)"
  extra_args="$(echo "$extra_args" | xargs)"

  project_dir="$PROJECTS_DIR/$project_rel"
  plist="$LAUNCH_DIR/${label}.plist"

  # launchd stdout/stderr go to ~/Library/Logs (not TCC-protected)
  # Script-internal reports still write to project's own log_dir_rel
  launchd_log_dir="$HOME/Library/Logs/sk-agent"

  # Derive log name from label suffix
  log_name="${label##*.}"

  # Build ProgramArguments — use sk-agent-run (compiled binary with FDA)
  # to cd into project dir and exec bash with the script.
  prog_args="        <string>$SK_AGENT_RUN</string>
        <string>$project_dir</string>
        <string>$script</string>"
  [ -n "$extra_args" ] && prog_args="$prog_args
        <string>$extra_args</string>"

  # Build schedule block
  schedule=""
  case "$sched_type" in
    interval)
      schedule="    <key>StartInterval</key>
    <integer>$sched_val</integer>"
      ;;
    calendar)
      schedule="$(gen_calendar "$sched_val")"
      ;;
    calendar_multi)
      schedule="$(gen_calendar_multi "$sched_val")"
      ;;
    keepalive)
      schedule="    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>"
      ;;
  esac

  # Generate plist
  plist_content="<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">
<plist version=\"1.0\">
<dict>
    <key>Label</key>
    <string>$label</string>

    <key>ProgramArguments</key>
    <array>
$prog_args
    </array>

$schedule

    <key>StandardOutPath</key>
    <string>$launchd_log_dir/${label}-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$launchd_log_dir/${label}-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>$AGENT_PATH</string>
    </dict>
</dict>
</plist>"

  if $DRY_RUN; then
    echo "=== $label ==="
    echo "$plist_content"
    echo
  else
    # Unload existing
    launchctl unload "$plist" 2>/dev/null || true

    # Ensure log dirs exist
    mkdir -p "$launchd_log_dir"

    # Write plist
    echo "$plist_content" > "$plist"

    # Load
    launchctl load "$plist" 2>/dev/null && echo "Loaded: $label" || echo "FAILED: $label"
  fi
done

if ! $DRY_RUN; then
  echo ""
  echo "Done. Verify with: launchctl list | grep com.sk"
fi
