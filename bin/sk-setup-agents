#!/usr/bin/env bash
# sk-setup-agents — DEPRECATED launchd installer (macOS).
#
# This host runs on Linux/WSL2 with systemd user units. The old launchd/plist
# path (~/Library/LaunchAgents, launchctl) does not exist here. Kept as a thin
# shim so existing callers (bin/sk bootstrap, docs) keep working — it just
# delegates to sk-setup-systemd, the real installer.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "[sk-setup-agents] deprecated → delegating to sk-setup-systemd" >&2

# Map the only flags that carried over; drop launchd-only ones.
args=()
for a in "$@"; do
  case "$a" in
    --dry-run) args+=("--dry-run") ;;
    --unload)  args+=("--stop") ;;
    *) ;;
  esac
done

exec "$REPO_DIR/bin/sk-setup-systemd" "${args[@]}"
