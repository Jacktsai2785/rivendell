    L_CICD="CI/CD"; L_CI="CI"; L_DEPLOY_CFG="部署"; L_HOOKS="Hooks"
    L_OVERVIEW="全部 Skills 功能一覽"; L_SKILL="Skill"; L_FUNCTION="功能"
  fi

  # Collect all skill dirs
  local skill_dirs=()
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    skill_dirs+=("$d")
    ((total++))
  done < <(all_skill_dirs)

  # --- Begin report ---
  {
    echo "# $L_TITLE — $today"
    echo ""
    echo "## $L_SUMMARY"
    echo ""

    # --- 1. Structural Health ---
    local dangling=0 missing_deploy=0 missing_tags=0 missing_version=0

    # Dangling symlinks
    if [ -d "$DEPLOY_TARGET" ]; then
      for link in "$DEPLOY_TARGET"/*; do
        if [ -L "$link" ] && [ ! -e "$link" ]; then
          ((dangling++))
        fi
      done
    fi

    # Per-skill checks
    local no_trigger=0
    local no_trigger_list=""
    local missing_tags_list="" missing_version_list="" missing_deploy_list=""

    for skill_dir in "${skill_dirs[@]}"; do
      local name
      name="$(basename "$skill_dir")"
      local target="$DEPLOY_TARGET/$name"

      # Deploy check
      if [ ! -L "$target" ]; then
        ((missing_deploy++))
        missing_deploy_list+="- $name\n"
      fi

      # Tags check
      local tags
      tags="$(get_frontmatter_field "$skill_dir" "tags")"
      if [ -z "$tags" ]; then
        ((missing_tags++))
        missing_tags_list+="- $name\n"
      fi

      # Version check
      local ver
      ver="$(get_frontmatter_field "$skill_dir" "version")"
      if [ -z "$ver" ]; then
        ((missing_version++))
        missing_version_list+="- $name\n"
      fi

      # Description quality: check for TRIGGER
      if ! grep -qi "TRIGGER" "$skill_dir/SKILL.md" 2>/dev/null; then
        ((no_trigger++))
        no_trigger_list+="- $name\n"
      fi
    done

    # Count issues
    local structural_issues=$((dangling + missing_deploy + missing_tags + missing_version))

    echo "## $L_STRUCT"
    echo ""
    if [ "$dangling" -eq 0 ]; then
      echo "- $L_SYMLINKS: OK"
    else
      echo "- $L_SYMLINKS: **$dangling dangling**"
      ((needs_attention += dangling))
    fi
    if [ "$missing_deploy" -eq 0 ]; then
      # shellcheck disable=SC2059
      printf -- "- $L_DEPLOY: OK ($(printf "$L_DEPLOYED_ALL" "$total"))\n"
    else
      # shellcheck disable=SC2059
      printf -- "- $L_DEPLOY: **$(printf "$L_NOT_DEPLOYED" "$missing_deploy")**\n"
      echo -e "$missing_deploy_list"
      ((needs_attention += missing_deploy))
    fi
    if [ "$missing_tags" -eq 0 ] && [ "$missing_version" -eq 0 ]; then
      echo "- $L_FRONTMATTER: OK"
    else
      [ "$missing_tags" -gt 0 ] && echo "- $L_FRONTMATTER: **$missing_tags missing tags**"
      [ "$missing_version" -gt 0 ] && echo "- $L_FRONTMATTER: **$missing_version missing version**"
      ((needs_attention += missing_tags + missing_version))
    fi
    echo ""

    # --- 2. Skill Lifecycle ---
    echo "## $L_LIFECYCLE"
    echo ""
    local developing_count=0 stable_count=0 abandoned_count=0 new_count=0

    # Collect lifecycle data into temp files: category|name|detail
    local tmp_new tmp_dev tmp_stable tmp_abandoned
    tmp_new="$(mktemp)"; tmp_dev="$(mktemp)"; tmp_stable="$(mktemp)"; tmp_abandoned="$(mktemp)"

    for skill_dir in "${skill_dirs[@]}"; do
      local name category
      name="$(basename "$skill_dir")"
      category="$(basename "$(dirname "$skill_dir")")"
      local skill_file="$skill_dir/SKILL.md"
      local last_commit_date
      last_commit_date="$(git -C "$REPO_DIR" log -1 --format='%ai' -- "$skill_file" 2>/dev/null | cut -d' ' -f1)"

      if [ -z "$last_commit_date" ]; then
        echo "$category|$name|$L_NOT_COMMITTED" >> "$tmp_new"
        ((new_count++))
        continue
      fi

      local commit_count
      commit_count="$(git -C "$REPO_DIR" rev-list --count HEAD -- "$skill_file" 2>/dev/null || echo 0)"

      local age
      age="$(days_since "$last_commit_date")"

      if [ "$age" -le 14 ] && [ "$commit_count" -gt 1 ]; then
        echo "$category|$name|${commit_count} $L_REVISIONS, ${age}${L_DAYS_AGO}" >> "$tmp_dev"
        ((developing_count++))
      elif [ "$age" -le 90 ]; then
        echo "$category|$name|${commit_count} $L_REV, ${age}${L_DAYS_AGO}" >> "$tmp_stable"
        ((stable_count++))
      else
        echo "$category|$name|${commit_count} $L_REV, ${age}${L_DAYS_AGO} ($last_commit_date)" >> "$tmp_abandoned"
        ((abandoned_count++))
      fi
    done

    echo "| $L_PHASE | $L_COUNT | $L_MEANING |"
    echo "|-------|-------|---------|"
    echo "| 🆕 $L_NEW | $new_count | $L_NEW_MEANING |"
    echo "| 🔧 $L_DEVELOPING | $developing_count | $L_DEV_MEANING |"
    echo "| ✅ $L_STABLE | $stable_count | $L_STABLE_MEANING |"
    echo "| ❓ $L_ABANDONED | $abandoned_count | $L_ABANDON_MEANING |"
    echo ""

    # Helper: print skills grouped by category from a tmp file
    _print_grouped() {
      local file="$1"
      [ ! -s "$file" ] && return
      local prev_cat=""
      sort "$file" | while IFS='|' read -r cat sname detail; do
        if [ "$cat" != "$prev_cat" ]; then
          [ -n "$prev_cat" ] && echo ""
          echo "**$cat/**"
          prev_cat="$cat"
        fi
        echo "- $sname — $detail"
      done
      echo ""
    }

    if [ "$new_count" -gt 0 ]; then
      echo "### 🆕 $L_NEW"
      echo ""
      _print_grouped "$tmp_new"
    fi
    if [ "$developing_count" -gt 0 ]; then
      echo "### 🔧 $L_DEVELOPING"
      echo ""
      _print_grouped "$tmp_dev"
    fi
    if [ "$abandoned_count" -gt 0 ]; then
      echo "### ❓ $L_ABANDONED"
      echo ""
      _print_grouped "$tmp_abandoned"
      ((needs_attention += abandoned_count))
    fi
    if [ "$stable_count" -gt 0 ]; then
      echo "<details><summary>✅ $L_STABLE ($stable_count)</summary>"
      echo ""
      _print_grouped "$tmp_stable"
      echo "</details>"
      echo ""
    fi

    rm -f "$tmp_new" "$tmp_dev" "$tmp_stable" "$tmp_abandoned"

    # --- 2b. Skill Overview (function summary per category) ---
    echo "## $L_OVERVIEW"
    echo ""

    # Collect category|name|summary into temp file
    local tmp_overview
    tmp_overview="$(mktemp)"
    for skill_dir in "${skill_dirs[@]}"; do
      local name category summary
      name="$(basename "$skill_dir")"
      category="$(basename "$(dirname "$skill_dir")")"
      summary="$(get_skill_summary "$skill_dir")"
      [ -z "$summary" ] && summary="—"
      echo "$category|$name|$summary" >> "$tmp_overview"
    done

    # Also include local-only skills (not in repo but deployed)
    if [ -d "$DEPLOY_TARGET" ]; then
      for deployed_dir in "$DEPLOY_TARGET"/*/; do
        [ ! -d "$deployed_dir" ] && continue
        local dname
        dname="$(basename "$deployed_dir")"
        # Skip if already in repo skills
        local already=0
        for skill_dir in "${skill_dirs[@]}"; do
          [ "$(basename "$skill_dir")" = "$dname" ] && already=1 && break
        done
        [ "$already" -eq 1 ] && continue
        # This is a local-only skill
        local summary
        summary="$(get_skill_summary "$deployed_dir")"
        [ -z "$summary" ] && summary="—"
        echo "local|$dname|$summary" >> "$tmp_overview"
      done
    fi

    # Print grouped by category
    local prev_cat=""
    sort "$tmp_overview" | while IFS='|' read -r cat sname summary; do
      if [ "$cat" != "$prev_cat" ]; then
        [ -n "$prev_cat" ] && echo ""
        echo "### $cat"
        echo ""
        echo "| $L_SKILL | $L_FUNCTION |"
        echo "|-------|------|"
        prev_cat="$cat"
      fi
      echo "| $sname | $summary |"
    done
    echo ""
    rm -f "$tmp_overview"

    # --- 3. Description Quality ---
    echo "## $L_DESC_QUALITY"
    echo ""
    if [ "$no_trigger" -eq 0 ]; then
      echo "$L_ALL_DESC_OK"
    else
      echo "### $L_MISSING_TRIGGER ($no_trigger)"
      echo ""
      echo -e "$no_trigger_list"
      ((needs_attention += no_trigger))
    fi

    # --- 4. Tag Overlap ---
    echo "## $L_TAG_OVERLAP"
    echo ""
    # Build tag-combo → skills mapping using temp file (bash 3 compat)
    local tmp_tags
    tmp_tags="$(mktemp)"
    for skill_dir in "${skill_dirs[@]}"; do
      local name
      name="$(basename "$skill_dir")"
      local tags
      tags="$(get_tags "$skill_dir")"
      if [ -n "$tags" ]; then
        local sorted_tags
        sorted_tags="$(echo "$tags" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | sort | tr '\n' ',' | sed 's/,$//')"
        echo "$sorted_tags|$name" >> "$tmp_tags"
      fi
    done

    local overlap_found=0
    while IFS= read -r combo; do
      [ -z "$combo" ] && continue
      local skills_in_group
      skills_in_group="$(grep "^${combo}|" "$tmp_tags" | cut -d'|' -f2 | tr '\n' ' ' | sed 's/ $//')"
      local word_count
      word_count=$(echo "$skills_in_group" | wc -w | tr -d ' ')
      if [ "$word_count" -gt 1 ]; then
        echo "- **[$combo]**: $skills_in_group — $L_REVIEW_BOUNDARY"
        ((overlap_found++))
      fi
    done < <(cut -d'|' -f1 "$tmp_tags" | sort -u)
    rm -f "$tmp_tags"

    if [ "$overlap_found" -eq 0 ]; then
      echo "$L_NO_OVERLAP"
    fi
    echo ""

    # --- 5. Project Dashboard ---
    echo "## $L_DASHBOARD"
    echo ""
    if [ -d "$PROJECTS_DIR" ]; then
      local proj_issues=0

      for proj_dir in "$PROJECTS_DIR"/*/; do
        [ ! -d "$proj_dir" ] && continue
        local proj_name
        proj_name="$(basename "$proj_dir")"
        [ "$proj_name" = "skills-test" ] && continue

        # --- Tech stack detection ---
        local techs=""
        { [ -f "$proj_dir/package.json" ] || find "$proj_dir" -maxdepth 2 -name "package.json" -print -quit 2>/dev/null | grep -q .; } && techs+="Node.js "
        { [ -f "$proj_dir/pyproject.toml" ] || [ -f "$proj_dir/requirements.txt" ]; } && techs+="Python "
        [ -f "$proj_dir/Cargo.toml" ] && techs+="Rust "
        [ -f "$proj_dir/go.mod" ] && techs+="Go "
        [ -f "$proj_dir/Package.swift" ] && techs+="Swift "
        { [ -f "$proj_dir/project.yml" ] || ls "$proj_dir"/*.xcodeproj 2>/dev/null | head -1 | grep -q .; } && techs+="Xcode "
        { [ -f "$proj_dir/firebase.json" ] || [ -f "$proj_dir/.firebaserc" ] || find "$proj_dir" -maxdepth 2 -name "firebase.json" -print -quit 2>/dev/null | grep -q .; } && techs+="Firebase "
        [ -f "$proj_dir/Dockerfile" ] && techs+="Docker "
        [ -f "$proj_dir/Makefile" ] && techs+="Make "
        [ -f "$proj_dir/Gemfile" ] && techs+="Ruby "
        ls "$proj_dir"/*.tf 2>/dev/null | head -1 | grep -q . && techs+="Terraform "
        techs="$(echo "$techs" | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/ $//')"

        # Skip projects with no detectable tooling
        [ -z "$techs" ] && continue

        # --- Config check ---
        local config_status=""
        local has_claude_md=0 has_agents_md=0
        [ -f "$proj_dir/.claude/CLAUDE.md" ] && has_claude_md=1
        [ -f "$proj_dir/AGENTS.md" ] && has_agents_md=1
        if [ "$has_claude_md" -eq 1 ] && [ "$has_agents_md" -eq 1 ]; then
          config_status="OK"
        elif [ "$has_claude_md" -eq 1 ]; then
          config_status="no AGENTS.md"
        elif [ "$has_agents_md" -eq 1 ]; then
          config_status="no CLAUDE.md"
        else
          config_status="**missing**"
          ((proj_issues++))
        fi

        # --- Permissions check ---
        local perm_status=""
        local settings_file="$proj_dir/.claude/settings.local.json"
        if [ -f "$settings_file" ]; then
          local oneoff_count=0
          oneoff_count="$(grep -cE '(git -C /|git commit -m "|find /Users|Bash\([A-Z])' "$settings_file" 2>/dev/null || true)"
          oneoff_count="${oneoff_count:-0}"; oneoff_count="${oneoff_count// /}"
          local colon_count=0
          colon_count="$(grep -cE 'Bash\([a-z]+:' "$settings_file" 2>/dev/null || true)"
          colon_count="${colon_count:-0}"; colon_count="${colon_count// /}"
          local total_perms=0
          total_perms="$(grep -cE '"Bash|"mcp_|"Read|"WebFetch|"WebSearch' "$settings_file" 2>/dev/null || true)"
          total_perms="${total_perms:-0}"; total_perms="${total_perms// /}"

          if [ "$oneoff_count" -gt 0 ] || [ "$colon_count" -gt 0 ]; then
            perm_status="**cleanup** (${oneoff_count} one-off, ${colon_count} colon-style)"
            ((proj_issues++))
          else
            perm_status="OK ($total_perms rules)"
          fi
        else
          perm_status="**missing**"
          ((proj_issues++))
        fi

        # --- CI/CD status ---
        local ci_status="" deploy_status="" hooks_status=""
        if [ -d "$proj_dir/.github/workflows" ] && ls "$proj_dir"/.github/workflows/*.yml "$proj_dir"/.github/workflows/*.yaml 2>/dev/null | head -1 | grep -q .; then
          ci_status="✅"
        else
          ci_status="❌"
        fi
        # Deploy config: fly.toml, vercel.json, wrangler.toml, docker-compose.prod.yml, Fastfile, firebase deploy in CI
        if [ -f "$proj_dir/fly.toml" ] || [ -f "$proj_dir/vercel.json" ] || [ -f "$proj_dir/wrangler.toml" ] || [ -f "$proj_dir/docker-compose.prod.yml" ] || [ -f "$proj_dir/fastlane/Fastfile" ] || grep -rql "firebase deploy" "$proj_dir/.github/workflows/" 2>/dev/null; then
          deploy_status="✅"
        else
          deploy_status="❌"
        fi
        if [ -f "$proj_dir/.pre-commit-config.yaml" ] || [ -d "$proj_dir/.husky" ] || grep -q '"pre-commit"' "$proj_dir/package.json" 2>/dev/null; then
          hooks_status="✅"
        else
          hooks_status="❌"
        fi

        # --- Git status ---
        local git_status="" dirty=0 unpushed=0
        if [ -d "$proj_dir/.git" ]; then
          dirty="$(git -C "$proj_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
          unpushed="$(git -C "$proj_dir" log --oneline '@{upstream}..HEAD' 2>/dev/null | wc -l | tr -d ' ')"
          if [ "$dirty" -gt 0 ] && [ "$unpushed" -gt 0 ]; then
            git_status="${dirty} dirty, ${unpushed} unpushed"
          elif [ "$dirty" -gt 0 ]; then
            git_status="${dirty} dirty"
          elif [ "$unpushed" -gt 0 ]; then
            git_status="${unpushed} unpushed"
          else
            git_status="clean"
          fi
        else
          git_status="no git"
        fi

        # --- Activity: commits in last 7 / 30 days ---
        local commits_7d=0 commits_30d=0 last_commit_date="" last_commit_msg=""
        if [ -d "$proj_dir/.git" ]; then
          commits_7d="$(git -C "$proj_dir" rev-list --count --since='7 days ago' HEAD 2>/dev/null || echo 0)"
          commits_30d="$(git -C "$proj_dir" rev-list --count --since='30 days ago' HEAD 2>/dev/null || echo 0)"
          last_commit_date="$(git -C "$proj_dir" log -1 --format='%Y-%m-%d' 2>/dev/null || echo '')"
          last_commit_msg="$(git -C "$proj_dir" log -1 --format='%s' 2>/dev/null | head -c 60)"
        fi

        # --- Activity level ---
        local activity_level=""
        if [ "$commits_7d" -gt 5 ]; then
          activity_level="🔥 $L_ACTIVE"
        elif [ "$commits_7d" -gt 0 ]; then
          activity_level="✅ $L_RECENT"
        elif [ "$commits_30d" -gt 0 ]; then
          activity_level="💤 $L_QUIET"
        else
          activity_level="⏸️ $L_PAUSED"
        fi

        # --- Branches ---
        local branch_count=0 current_branch=""
        if [ -d "$proj_dir/.git" ]; then
          branch_count="$(git -C "$proj_dir" branch --no-color 2>/dev/null | wc -l | tr -d ' ')"
          current_branch="$(git -C "$proj_dir" branch --show-current 2>/dev/null)"
        fi

        # --- Open PRs ---
        local open_prs=""
        if [ -d "$proj_dir/.git" ]; then
          local remote_url
          remote_url="$(git -C "$proj_dir" remote get-url origin 2>/dev/null || echo '')"
          if [ -n "$remote_url" ]; then
            local pr_count
            pr_count="$(gh pr list --repo "$remote_url" --state open --limit 10 --json number 2>/dev/null | python3 -c 'import json,sys; print(len(json.load(sys.stdin)))' 2>/dev/null || echo '0')"
            if [ "$pr_count" -gt 0 ]; then
              open_prs=" | ${pr_count} $L_OPEN_PR"
            fi
          fi
        fi

        # --- Print project block ---
        echo "### $proj_name"
        echo ""
        echo "| | |"
        echo "|---|---|"
        echo "| **$L_STATUS** | $activity_level — $commits_7d $L_COMMITS_WEEK, $commits_30d $L_COMMITS_MONTH |"
        echo "| **$L_STACK** | $techs |"
        echo "| **$L_BRANCH** | \`$current_branch\` ($branch_count total)$open_prs |"
        echo "| **$L_GIT** | $git_status |"
        echo "| **$L_CICD** | $L_CI $ci_status · $L_DEPLOY_CFG $deploy_status · $L_HOOKS $hooks_status |"
        echo "| **$L_CONFIG** | $config_status | **$L_PERMS** | $perm_status |"
        echo ""

        # Recent commits
        if [ -d "$proj_dir/.git" ]; then
          local recent_commits
          recent_commits="$(git -C "$proj_dir" log --oneline --no-decorate -5 2>/dev/null)"
          if [ -n "$recent_commits" ]; then
            echo "<details><summary>$L_RECENT_COMMITS</summary>"
            echo ""
            echo '```'
            echo "$recent_commits"
            echo '```'
            echo "</details>"
            echo ""
          fi
        fi
      done

      if [ "$proj_issues" -gt 0 ]; then
        echo "**$proj_issues $L_PROJ_ISSUES**"
        ((needs_attention += proj_issues))
      else
        echo "$L_ALL_HEALTHY"
      fi
    else
      echo "Projects directory not found at $PROJECTS_DIR"
    fi

    # --- 6. Agent Health ---
    echo "## $L_AGENT_HEALTH"
    echo ""
    local agent_count=0
    agent_count="$(agent_scan_all | wc -l | tr -d ' ')"
    if [ "$agent_count" -gt 0 ]; then
      echo "| $L_AGENT_PROJECT | $L_AGENT_NAME | $L_AGENT_SCHED | $L_AGENT_STATUS | $L_AGENT_EXIT |"
      echo "|---------|-------|----------|--------|-----------|"
      local agent_issues=0
      agent_health_report "markdown" || agent_issues=$?
      echo ""
      if [ "$agent_issues" -gt 0 ]; then
        echo "**${agent_issues} ${L_AGENT_ISSUES}**"
        ((needs_attention += agent_issues))
      else
        echo "$L_AGENT_ALL_OK"
      fi
    else
      echo "$L_NO_AGENTS"
    fi
    echo ""

    # --- 7. Token Usage (7-day trend) ---
    echo "## $L_TOKEN"
    echo ""
    local token_output
    token_output="$(python3 -c "
import json, os, glob
from collections import defaultdict
from datetime import datetime, timedelta

lang = '$lang'
base = os.path.expanduser('~/.claude/projects/')
dates = [(datetime.now() - timedelta(days=i)).strftime('%Y-%m-%d') for i in range(6, -1, -1)]

# Per-day and per-project aggregation
daily = {d: defaultdict(int) for d in dates}
daily_sessions = {d: 0 for d in dates}
daily_calls = {d: 0 for d in dates}
proj_totals = defaultdict(lambda: defaultdict(int))

for pdir in glob.glob(os.path.join(base, '*/')):
    dir_name = os.path.basename(pdir.rstrip('/'))
    proj = dir_name.split('-Users-manibari-Documents-Projects-')[-1] if '-Users-manibari-Documents-Projects-' in dir_name else dir_name
    proj = proj.rstrip('-')

    for f in glob.glob(os.path.join(pdir, '*.jsonl')):
        day_found = set()
        try:
            for line in open(f):
                try:
                    obj = json.loads(line)
                except:
                    continue
                ts = obj.get('timestamp', '')
                day = ts[:10]
                if day not in daily:
                    continue
                day_found.add(day)
                if obj.get('type') == 'assistant':
                    msg = obj.get('message', {})
                    if isinstance(msg, dict) and 'usage' in msg:
                        u = msg['usage']
                        inp = u.get('input_tokens', 0)
                        out = u.get('output_tokens', 0)
                        cc = u.get('cache_creation_input_tokens', 0)
                        cr = u.get('cache_read_input_tokens', 0)
                        daily[day]['input'] += inp
                        daily[day]['output'] += out
                        daily[day]['cache_create'] += cc
                        daily[day]['cache_read'] += cr
                        daily_calls[day] += 1
                        proj_totals[proj]['input'] += inp
                        proj_totals[proj]['output'] += out
                        proj_totals[proj]['cache_create'] += cc
                        proj_totals[proj]['cache_read'] += cr
                        proj_totals[proj]['calls'] += 1
        except:
            continue
        for d in day_found:
            daily_sessions[d] += 1

def fmt_tokens(n):
    if n >= 1_000_000: return f'{n/1_000_000:.1f}M'
    if n >= 1_000: return f'{n/1_000:.0f}K'
    return str(n)

def calc_cost(d):
    return (d['input'] * 15 + d['output'] * 75 + d['cache_create'] * 18.75 + d['cache_read'] * 1.50) / 1_000_000

# i18n
L = {
    'trend': '7-Day Trend' if lang == 'en' else '7 日趨勢',
    'cost_title': 'Daily Cost (USD)' if lang == 'en' else '每日花費（USD）',
    'date': 'Date' if lang == 'en' else '日期',
    'sessions': 'Sessions',
    'api_calls': 'API Calls' if lang == 'en' else 'API 呼叫',
    'tokens': 'Tokens',
    'cost': 'Est. Cost' if lang == 'en' else '預估花費',
    'cost_by_proj': 'Cost by Project (7 days)' if lang == 'en' else '各專案花費（7 日）',
    'project': 'Project' if lang == 'en' else '專案',
    'pricing': 'Pricing: Opus input \$15/M, output \$75/M, cache create \$18.75/M, cache read \$1.50/M' if lang == 'en' else '計價: Opus input \$15/M, output \$75/M, cache create \$18.75/M, cache read \$1.50/M',
}

# Compute costs for chart
costs = []
labels = []
for d in dates:
    t = daily[d]
    cost = calc_cost(t)
    costs.append(cost)
    labels.append(d[5:])  # MM-DD

# Mermaid xychart trend
print(f'### {L[\"trend\"]}')
print()
print('~~~mermaid')
print('xychart-beta')
print(f'    title \"{L[\"cost_title\"]}\"')
x_labels = ', '.join(f'\"{lb}\"' for lb in labels)
print(f'    x-axis [{x_labels}]')
max_y = max(costs) if any(c > 0 for c in costs) else 100
max_y = int((max_y // 50 + 2) * 50)  # round up to nice number
print(f'    y-axis \"USD\" 0 --> {max_y}')
cost_vals = ', '.join(f'{c:.0f}' for c in costs)
print(f'    bar [{cost_vals}]')
print('~~~')
print()

# Detail table
week_total_tokens = 0
week_total_cost = 0.0
print(f'| {L[\"date\"]} | {L[\"sessions\"]} | {L[\"api_calls\"]} | {L[\"tokens\"]} | {L[\"cost\"]} |')
print('|------|----------|-----------|--------|-----------|')
for i, d in enumerate(dates):
    t = daily[d]
    total = t['input'] + t['output'] + t['cache_create'] + t['cache_read']
    cost = costs[i]
    week_total_tokens += total
    week_total_cost += cost
    dow = datetime.strptime(d, '%Y-%m-%d').strftime('%a')
    print(f'| {d} ({dow}) | {daily_sessions[d]} | {daily_calls[d]:,} | {fmt_tokens(total)} | \${cost:.2f} |')
print(f'| **Total** | | | **{fmt_tokens(week_total_tokens)}** | **\${week_total_cost:.2f}** |')
print()

# Per-project breakdown
if proj_totals:
    print(f'### {L[\"cost_by_proj\"]}')
    print()
    print(f'| {L[\"project\"]} | {L[\"api_calls\"]} | {L[\"tokens\"]} | {L[\"cost\"]} |')
    print('|---------|-----------|--------|-----------|')
    sorted_projs = sorted(proj_totals.items(), key=lambda x: calc_cost(x[1]), reverse=True)
    for proj, d in sorted_projs:
        total = d['input'] + d['output'] + d['cache_create'] + d['cache_read']
        cost = calc_cost(d)
        if total == 0:
            continue
        print(f'| {proj} | {d[\"calls\"]:,} | {fmt_tokens(total)} | \${cost:.2f} |')
    print()

print(f'_{L[\"pricing\"]}_')
" 2>/dev/null)"
    if [ -n "$token_output" ]; then
      echo "$token_output"
    else
      echo "No token data available (current session not yet saved)."
    fi
    echo ""

    # --- Summary line ---
    healthy=$((total - needs_attention))
    [ "$healthy" -lt 0 ] && healthy=0

    echo ""
    echo "---"
    echo ""
    echo "*$L_GENERATED \`./bin/sk audit\` — $today — $total skills, $needs_attention issue(s)*"

  } > "$report"

  # Insert summary at top (after ## heading)
  sed -i '' "/^## $L_SUMMARY$/a\\
\\
- **$L_TOTAL:** $total skills\\
- **$L_ATTENTION:** $needs_attention issue(s)\\
" "$report"

  echo -e "${GREEN}Report generated:${NC} $report"
  echo ""
  # Print summary to terminal
  echo -e "${CYAN}=== Skill Audit Summary ===${NC}"
  echo -e "  Total:           $total skills"
  echo -e "  Needs Attention: ${needs_attention} issue(s)"
  echo -e "  Report:          $report"
}

# Main dispatch
case "${1:-help}" in
  deploy)     cmd_deploy ;;
  undeploy)   cmd_undeploy ;;
  create)     cmd_create "${2:-}" ;;
  import)     cmd_import "${2:-}" ;;
  import-gh)  cmd_import_gh "${2:-}" ;;
  list)       cmd_list ;;
  check)      cmd_check "${2:-}" ;;
  audit)      shift; cmd_audit "$@" ;;
  permissions) cmd_permissions "${2:-.}" ;;
  maintain)   cmd_maintain ;;
  agent)      shift; cmd_agent "$@" ;;
  sync)       cmd_sync ;;
  help|--help|-h) usage ;;
  *)
    echo -e "${RED}Unknown command:${NC} $1"
    usage
    exit 1
    ;;
esac
