#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$REPO_DIR/skills"
DEPLOY_TARGET="$HOME/.claude/skills"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
  cat <<EOF
Usage: ./bin/sk <command> [args]

Commands:
  deploy              Symlink all skills → ~/.claude/skills/
  undeploy            Remove repo symlinks from ~/.claude/skills/
  create <cat/name>   Scaffold new skill + auto-deploy (e.g. meta/my-skill)
  import <name>       Import from SkillsMP via agent-skills-cli
  import-gh <url>     Clone skill from GitHub URL
  list                Show all skills + deployment status
  check [--verbose]   Health check: symlinks, reviews, gdrive, frontmatter
  audit               Generate audit report → reports/skill-audit-YYYY-MM-DD.md
  permissions [dir]   Scan project tooling and update .claude/settings.local.json
  maintain            Nightly maintenance: permissions sync, deploy check, agent health, audit
  sync                Show Google Drive import status for re-import
  agent               Manage automated agents (list/start/stop/status/log/create)
  help                Show this help message

Categories: meta, workflow, quality, git, frontend, backend, docs
  Total: 28 skills
EOF
}

# Find all skill directories (any that contain SKILL.md)
all_skill_dirs() {
  find "$SKILLS_DIR" -name "SKILL.md" -maxdepth 3 -exec dirname {} \; | sort
}

# Get category from skill path
get_category() {
  local skill_dir="$1"
  local rel="${skill_dir#$SKILLS_DIR/}"
  echo "${rel%%/*}"
}

cmd_deploy() {
  mkdir -p "$DEPLOY_TARGET"
  local count=0
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local target="$DEPLOY_TARGET/$name"
    if [ -L "$target" ]; then
      echo -e "${YELLOW}skip${NC}  $name (already linked)"
    elif [ -e "$target" ]; then
      echo -e "${RED}skip${NC}  $name (non-symlink exists at target)"
    else
      ln -s "$skill_dir" "$target"
      echo -e "${GREEN}link${NC}  $name → $target"
      ((count++))
    fi
  done < <(all_skill_dirs)
  echo -e "\n${GREEN}Deployed $count skill(s).${NC}"
}

cmd_undeploy() {
  local count=0
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local target="$DEPLOY_TARGET/$name"
    if [ -L "$target" ]; then
      local link_dest
      link_dest="$(readlink "$target")"
      # Only remove if it points back into our repo
      if [[ "$link_dest" == "$REPO_DIR"/* ]]; then
        rm "$target"
        echo -e "${GREEN}unlink${NC}  $name"
        ((count++))
      fi
    fi
  done < <(all_skill_dirs)
  echo -e "\n${GREEN}Undeployed $count skill(s).${NC}"
}

cmd_create() {
  local input="${1:?Usage: sk create <category/name> (e.g. meta/my-skill)}"

  # Support both "category/name" and plain "name" (defaults to meta)
  if [[ "$input" == */* ]]; then
    local category="${input%%/*}"
    local name="${input#*/}"
  else
    local category="meta"
    local name="$input"
  fi

  local dir="$SKILLS_DIR/$category/$name"
  if [ -d "$dir" ]; then
    echo -e "${RED}Error:${NC} Skill '$name' already exists at $dir"
    exit 1
  fi
  mkdir -p "$dir"
  cat > "$dir/SKILL.md" <<TEMPLATE
---
name: $name
description: TODO - describe what this skill does
tags: [$category]
version: 1
source: manual
user_invocable: true
---

# $name

## Instructions

TODO - write skill instructions here.
TEMPLATE
  echo -e "${GREEN}Created${NC} $dir/SKILL.md"

  # Auto-deploy: create symlink immediately
  mkdir -p "$DEPLOY_TARGET"
  local target="$DEPLOY_TARGET/$name"
  if [ -L "$target" ] || [ -e "$target" ]; then
    echo -e "${YELLOW}Note:${NC} $target already exists, skipping auto-deploy."
  else
    ln -s "$dir" "$target"
    echo -e "${GREEN}Deployed${NC} $name → $target"
  fi
  echo "Edit the file to add your skill instructions."
}

cmd_import() {
  local name="${1:?Usage: sk import <name>}"
  if ! command -v skills &>/dev/null; then
    echo -e "${RED}Error:${NC} skills CLI not found. Install with: npm install -g agent-skills-cli"
    exit 1
  fi
  # Install to Claude Code's skills dir, then move to our repo for tracking
  skills install "$name" --agent claude -y
  local claude_dir="$HOME/.claude/skills/$name"
  # Default import to workflow/ — user can move to correct category later
  local dest="$SKILLS_DIR/workflow/$name"
  if [ -d "$claude_dir" ] && [ ! -L "$claude_dir" ]; then
    mkdir -p "$SKILLS_DIR/workflow"
    mv "$claude_dir" "$dest"
    echo -e "${GREEN}Imported${NC} $name → $dest"
    echo -e "${YELLOW}Note:${NC} Placed in workflow/. Move to correct category if needed."
    echo "Run './bin/sk deploy' to symlink it back."
  else
    echo -e "${GREEN}Installed${NC} $name via skills CLI"
  fi
}

cmd_import_gh() {
  local url="${1:?Usage: sk import-gh <github-url>}"
  local name
  name="$(basename "$url" .git)"
  # Default import to workflow/
  local dest="$SKILLS_DIR/workflow/$name"
  if [ -d "$dest" ]; then
    echo -e "${YELLOW}Updating${NC} $name..."
    git -C "$dest" pull
  else
    mkdir -p "$SKILLS_DIR/workflow"
    git clone "$url" "$dest"
  fi
  echo -e "${GREEN}Imported${NC} $name → $dest"
  echo -e "${YELLOW}Note:${NC} Placed in workflow/. Move to correct category if needed."
}

get_tags() {
  local skill_md="$1/SKILL.md"
  if [ -f "$skill_md" ]; then
    sed -n '/^---$/,/^---$/p' "$skill_md" \
      | grep -E '^tags:' \
      | sed 's/^tags:[[:space:]]*//' \
      | tr -d '[]' \
      | xargs \
      || true
  fi
}

get_frontmatter_field() {
  local skill_dir="$1"
  local field="$2"
  local skill_md="$skill_dir/SKILL.md"
  if [ -f "$skill_md" ]; then
    sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$skill_md" \
      | grep -m1 -E "^${field}:" \
      | sed "s/^${field}:[[:space:]]*//" \
      | tr -d '"'"'" \
      || true
  fi
}

get_skill_summary() {
  # Extract one-line description from SKILL.md frontmatter
  # Handles both: "description: text" and "description: >\n  text"
  local skill_dir="$1"
  local skill_md="$skill_dir/SKILL.md"
  [ ! -f "$skill_md" ] && return
  local desc_line
  desc_line="$(sed -n '/^---$/,/^---$/{/^---$/d;p;}' "$skill_md" | grep -m1 '^description:')"
  local val="${desc_line#description:}"
  val="$(echo "$val" | sed 's/^[[:space:]]*//' | tr -d '"'"'")"
  if [ "$val" = ">" ] || [ -z "$val" ]; then
    # Multiline: grab all indented lines, join them
    val="$(sed -n '/^description:/,/^[^ ]/{/^description:/d;/^[^ ]/d;p;}' "$skill_md" | sed 's/^[[:space:]]*//' | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
    # Strip TRIGGER/DO NOT TRIGGER suffix
    val="$(echo "$val" | sed 's/[[:space:]]*TRIGGER when:.*//' | sed 's/[[:space:]]*DO NOT TRIGGER.*//' | sed 's/[[:space:]]*$//')"
  fi
  # If val is empty (description was only TRIGGER text), try when_to_use or H1 subtitle
  if [ -z "$val" ]; then
    val="$(sed -n '/^---$/,/^---$/{/^---$/d;p;}' "$skill_md" | grep -m1 '^when_to_use:' | sed 's/^when_to_use:[[:space:]]*//')"
  fi
  if [ -z "$val" ]; then
    # Fallback: first non-empty line after frontmatter that isn't a heading
    val="$(sed -n '/^---$/,/^---$/!p' "$skill_md" | sed '1,/^---$/d' | grep -v '^#' | grep -v '^$' | head -1 | sed 's/^[[:space:]]*//')"
  fi
  # Strip TRIGGER text from single-line descriptions too
  val="$(echo "$val" | sed 's/[[:space:]]*TRIGGER when:.*//' | sed 's/[[:space:]]*$//')"
  # Truncate at first period-space if still long, cap at 120 chars
  if [ "${#val}" -gt 120 ]; then
    val="$(echo "$val" | sed 's/\. .*/\./')"
  fi
  [ "${#val}" -gt 120 ] && val="${val:0:117}..."
  echo "$val"
}

days_since() {
  local date_str="$1"
  [ -z "$date_str" ] && echo -1 && return
  local target_epoch
  if date -j -f "%Y-%m-%d" "$date_str" "+%s" &>/dev/null; then
    target_epoch=$(date -j -f "%Y-%m-%d" "$date_str" "+%s")
  elif date -d "$date_str" "+%s" &>/dev/null; then
    target_epoch=$(date -d "$date_str" "+%s")
  else
    echo -1 && return
  fi
  local now_epoch
  now_epoch=$(date "+%s")
  echo $(( (now_epoch - target_epoch) / 86400 ))
}

cmd_check() {
  local verbose=0
  [ "${1:-}" = "--verbose" ] && verbose=1

  local stale_days="${SK_STALE_DAYS:-90}"

  echo -e "${CYAN}=== Skill Health Check ===${NC}\n"

  # --- Symlinks ---
  echo -e "${CYAN}[Symlinks]${NC}"
  local dangling=0 missing=0 conflict=0 collision=0
  local dangling_list="" missing_list="" conflict_list="" collision_list=""

  # Check for dangling symlinks in deploy target
  if [ -d "$DEPLOY_TARGET" ]; then
    while IFS= read -r link; do
      [ -z "$link" ] && continue
      if [ -L "$link" ] && [ ! -e "$link" ]; then
        ((dangling++))
        dangling_list+="    $(basename "$link") → $(readlink "$link")\n"
      fi
    done < <(find "$DEPLOY_TARGET" -maxdepth 1 -type l 2>/dev/null)
  fi

  # Check each skill for deploy status and collisions
  local seen_names=""
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local target="$DEPLOY_TARGET/$name"

    # Name collision detection
    if echo "$seen_names" | grep -qx "$name"; then
      ((collision++))
      collision_list+="    $name (${skill_dir#$REPO_DIR/})\n"
    fi
    seen_names+="$name"$'\n'

    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ((missing++))
      missing_list+="    $name (${skill_dir#$REPO_DIR/})\n"
    elif [ -e "$target" ] && [ ! -L "$target" ]; then
      ((conflict++))
      conflict_list+="    $name (non-symlink at $target)\n"
    fi
  done < <(all_skill_dirs)

  if [ "$dangling" -gt 0 ]; then
    echo -e "  ${RED}$dangling dangling symlink(s) found${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$dangling_list"
    echo -e "  ${YELLOW}Clean up with:${NC} find $DEPLOY_TARGET -maxdepth 1 -xtype l -delete"
  fi
  if [ "$missing" -gt 0 ]; then
    echo -e "  ${YELLOW}$missing skill(s) not deployed${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$missing_list"
  fi
  if [ "$conflict" -gt 0 ]; then
    echo -e "  ${RED}$conflict non-symlink conflict(s)${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$conflict_list"
  fi
  if [ "$collision" -gt 0 ]; then
    echo -e "  ${RED}$collision name collision(s) across categories${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$collision_list"
  fi
  if [ "$dangling" -eq 0 ] && [ "$missing" -eq 0 ] && [ "$conflict" -eq 0 ] && [ "$collision" -eq 0 ]; then
    echo -e "  ${GREEN}All symlinks OK${NC}"
  fi

  # --- Reviews ---
  echo ""
  echo -e "${CYAN}[Reviews]${NC}"
  local stale=0 no_review=0
  local stale_list="" no_review_list=""
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local reviewed
    reviewed="$(get_frontmatter_field "$skill_dir" "last_reviewed")"
    if [ -z "$reviewed" ]; then
      ((no_review++))
      no_review_list+="    $name\n"
    else
      local age
      age="$(days_since "$reviewed")"
      if [ "$age" -ge 0 ] && [ "$age" -gt "$stale_days" ]; then
        ((stale++))
        stale_list+="    $name (${age}d ago)\n"
      fi
    fi
  done < <(all_skill_dirs)
  if [ "$stale" -gt 0 ]; then
    echo -e "  ${YELLOW}$stale skill(s) stale (>${stale_days} days)${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$stale_list"
  fi
  if [ "$no_review" -gt 0 ]; then
    echo -e "  ${YELLOW}$no_review skill(s) have no last_reviewed date${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$no_review_list"
  fi
  if [ "$stale" -eq 0 ] && [ "$no_review" -eq 0 ]; then
    echo -e "  ${GREEN}All reviews OK${NC}"
  fi

  # --- GDrive ---
  echo ""
  echo -e "${CYAN}[Google Drive]${NC}"
  local gdrive_stale=0
  local gdrive_list=""
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local source
    source="$(get_frontmatter_field "$skill_dir" "source")"
    if [[ "$source" == gdrive:* ]]; then
      local imported_at
      imported_at="$(get_frontmatter_field "$skill_dir" "imported_at")"
      local age
      age="$(days_since "$imported_at")"
      if [ "$age" -ge 0 ] && [ "$age" -gt "$stale_days" ]; then
        ((gdrive_stale++))
        gdrive_list+="    $name (imported ${age}d ago)\n"
      elif [ "$age" -lt 0 ]; then
        ((gdrive_stale++))
        gdrive_list+="    $name (no imported_at date)\n"
      fi
    fi
  done < <(all_skill_dirs)
  if [ "$gdrive_stale" -gt 0 ]; then
    echo -e "  ${YELLOW}$gdrive_stale gdrive skill(s) may need re-import${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$gdrive_list"
  else
    echo -e "  ${GREEN}No stale gdrive imports${NC}"
  fi

  # --- Frontmatter ---
  echo ""
  echo -e "${CYAN}[Frontmatter]${NC}"
  local missing_tags=0 missing_version=0
  local missing_tags_list="" missing_version_list=""
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local tags
    tags="$(get_frontmatter_field "$skill_dir" "tags")"
    if [ -z "$tags" ]; then
      ((missing_tags++))
      missing_tags_list+="    $name\n"
    fi
    local version
    version="$(get_frontmatter_field "$skill_dir" "version")"
    if [ -z "$version" ]; then
      ((missing_version++))
      missing_version_list+="    $name\n"
    fi
  done < <(all_skill_dirs)
  if [ "$missing_tags" -gt 0 ]; then
    echo -e "  ${YELLOW}$missing_tags skill(s) missing 'tags'${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$missing_tags_list"
  fi
  if [ "$missing_version" -gt 0 ]; then
    echo -e "  ${YELLOW}$missing_version skill(s) missing 'version'${NC}"
    [ "$verbose" -eq 1 ] && echo -e "$missing_version_list"
  fi
  if [ "$missing_tags" -eq 0 ] && [ "$missing_version" -eq 0 ]; then
    echo -e "  ${GREEN}All frontmatter OK${NC}"
  fi

  echo ""
}

cmd_sync() {
  echo -e "${CYAN}=== Google Drive Skill Sync Status ===${NC}\n"
  local found=0
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local source
    source="$(get_frontmatter_field "$skill_dir" "source")"
    if [[ "$source" == gdrive:* ]]; then
      found=1
      local imported_at source_modified
      imported_at="$(get_frontmatter_field "$skill_dir" "imported_at")"
      source_modified="$(get_frontmatter_field "$skill_dir" "source_modified")"
      echo -e "  ${CYAN}$name${NC}"
      echo "    source:          $source"
      echo "    imported_at:     ${imported_at:-(not set)}"
      echo "    source_modified: ${source_modified:-(not set)}"
      echo ""
    fi
  done < <(all_skill_dirs)
  if [ "$found" -eq 0 ]; then
    echo "  No Google Drive imported skills found."
  else
    echo -e "  ${YELLOW}To re-import, run /gdrive-to-skills in Claude Code${NC}"
  fi
}

cmd_list() {
  echo -e "${CYAN}Skills:${NC}\n"
  local current_cat=""
  local found=0
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    found=1
    local name
    name="$(basename "$skill_dir")"
    local category
    category="$(get_category "$skill_dir")"

    # Print category header
    if [ "$category" != "$current_cat" ]; then
      [ -n "$current_cat" ] && echo ""
      echo -e "  ${CYAN}[$category]${NC}"
      current_cat="$category"
    fi

    local status
    local target="$DEPLOY_TARGET/$name"
    if [ -L "$target" ]; then
      status="${GREEN}[deployed]${NC}"
    else
      status="${YELLOW}[not deployed]${NC}"
    fi

    local tags
    tags="$(get_tags "$skill_dir")"
    if [ -n "$tags" ]; then
      printf "    %-35s %b  ${CYAN}#%s${NC}\n" "$name" "$status" "$tags"
    else
      printf "    %-35s %b\n" "$name" "$status"
    fi
  done < <(all_skill_dirs)
  if [ "$found" -eq 0 ]; then
    echo "  (no skills found)"
  fi
}

PROJECTS_DIR="$HOME/Documents/Projects"

# --- Permissions ---

cmd_permissions() {
  local proj_dir="${1:-.}"
  proj_dir="$(cd "$proj_dir" && pwd)"
  local proj_name
  proj_name="$(basename "$proj_dir")"

  echo -e "${CYAN}=== Permission Scan: $proj_name ===${NC}\n"

  # Read global baseline to avoid duplicates
  local global_settings="$HOME/.claude/settings.json"
  local global_perms=""
  if [ -f "$global_settings" ]; then
    global_perms="$(cat "$global_settings")"
  fi

  # Collect permissions to add
  local perms=()

  # Helper: add permission if not in global baseline
  add_perm() {
    local p="$1"
    if ! echo "$global_perms" | grep -qF "\"$p\""; then
      # Check if not already in perms array
      local already=0
      for existing in "${perms[@]+"${perms[@]}"}"; do
        [ "$existing" = "$p" ] && already=1 && break
      done
      [ "$already" -eq 0 ] && perms+=("$p")
    fi
  }

  # --- Detect tooling ---

  # Node.js
  if [ -f "$proj_dir/package.json" ]; then
    add_perm "Bash(npm *)"
    add_perm "Bash(npx *)"
    add_perm "Bash(node *)"

    # Package manager variants
    if [ -f "$proj_dir/bun.lock" ] || [ -f "$proj_dir/bun.lockb" ]; then
      add_perm "Bash(bun *)"
      add_perm "Bash(bunx *)"
      echo -e "  ${GREEN}+${NC} bun"
    fi
    if [ -f "$proj_dir/yarn.lock" ]; then
      add_perm "Bash(yarn *)"
      echo -e "  ${GREEN}+${NC} yarn"
    fi
    if [ -f "$proj_dir/pnpm-lock.yaml" ]; then
      add_perm "Bash(pnpm *)"
      add_perm "Bash(pnpx *)"
      echo -e "  ${GREEN}+${NC} pnpm"
    fi

    # JS/TS tools from package.json
    local pkg_content
    pkg_content="$(cat "$proj_dir/package.json" 2>/dev/null)"
    if echo "$pkg_content" | grep -q '"vitest"'; then
      add_perm "Bash(vitest *)" && add_perm "Bash(npx vitest *)"
      echo -e "  ${GREEN}+${NC} vitest"
    fi
    if echo "$pkg_content" | grep -q '"jest"'; then
      add_perm "Bash(jest *)" && add_perm "Bash(npx jest *)"
      echo -e "  ${GREEN}+${NC} jest"
    fi
    if echo "$pkg_content" | grep -q '"eslint"'; then
      add_perm "Bash(eslint *)" && add_perm "Bash(npx eslint *)"
      echo -e "  ${GREEN}+${NC} eslint"
    fi
    if echo "$pkg_content" | grep -q '"prettier"'; then
      add_perm "Bash(prettier *)" && add_perm "Bash(npx prettier *)"
      echo -e "  ${GREEN}+${NC} prettier"
    fi
    if echo "$pkg_content" | grep -q '"next"'; then
      add_perm "Bash(next *)" && add_perm "Bash(npx next *)"
      echo -e "  ${GREEN}+${NC} next.js"
    fi
    if echo "$pkg_content" | grep -q '"nuxt\|"nuxi"'; then
      add_perm "Bash(nuxt *)" && add_perm "Bash(npx nuxi *)" && add_perm "Bash(npx nuxt *)"
      echo -e "  ${GREEN}+${NC} nuxt"
    fi
    if echo "$pkg_content" | grep -q '"turbo"'; then
      add_perm "Bash(turbo *)" && add_perm "Bash(npx turbo *)"
      echo -e "  ${GREEN}+${NC} turbo"
    fi
    if echo "$pkg_content" | grep -q '"wrangler"'; then
      add_perm "Bash(wrangler *)" && add_perm "Bash(npx wrangler *)"
      echo -e "  ${GREEN}+${NC} wrangler"
    fi
    if echo "$pkg_content" | grep -q '"tsx"'; then
      add_perm "Bash(npx tsx *)"
      echo -e "  ${GREEN}+${NC} tsx"
    fi
    if echo "$pkg_content" | grep -q '"playwright"'; then
      add_perm "Bash(playwright *)" && add_perm "Bash(npx playwright *)"
      echo -e "  ${GREEN}+${NC} playwright (js)"
    fi
    if echo "$pkg_content" | grep -q '"prisma"'; then
      add_perm "Bash(npx prisma *)"
      echo -e "  ${GREEN}+${NC} prisma"
    fi
    if echo "$pkg_content" | grep -q '"drizzle"'; then
      add_perm "Bash(npx drizzle-kit *)"
      echo -e "  ${GREEN}+${NC} drizzle"
    fi
    echo -e "  ${GREEN}+${NC} node.js (npm/npx)"
  fi

  # Python
  if [ -f "$proj_dir/pyproject.toml" ] || [ -f "$proj_dir/requirements.txt" ]; then
    add_perm "Bash(python *)"
    add_perm "Bash(python3 *)"
    add_perm "Bash(pip *)"
    add_perm "Bash(pip3 *)"
    echo -e "  ${GREEN}+${NC} python"

    local py_content=""
    [ -f "$proj_dir/pyproject.toml" ] && py_content="$(cat "$proj_dir/pyproject.toml" 2>/dev/null)"
    [ -f "$proj_dir/requirements.txt" ] && py_content+="$(cat "$proj_dir/requirements.txt" 2>/dev/null)"

    if echo "$py_content" | grep -qi "poetry"; then
      add_perm "Bash(poetry *)"
      echo -e "  ${GREEN}+${NC} poetry"
    fi
    if echo "$py_content" | grep -qi "\[tool.uv\]\|uv.lock"; then
      add_perm "Bash(uv *)"
      echo -e "  ${GREEN}+${NC} uv"
    fi
    [ -f "$proj_dir/uv.lock" ] && add_perm "Bash(uv *)"
    if echo "$py_content" | grep -qi "pytest"; then
      add_perm "Bash(pytest *)" && add_perm "Bash(python -m pytest *)"
      echo -e "  ${GREEN}+${NC} pytest"
    fi
    if echo "$py_content" | grep -qi "ruff"; then
      add_perm "Bash(ruff *)"
      echo -e "  ${GREEN}+${NC} ruff"
    fi
    if echo "$py_content" | grep -qi "black"; then
      add_perm "Bash(black *)"
      echo -e "  ${GREEN}+${NC} black"
    fi
    if echo "$py_content" | grep -qi "mypy"; then
      add_perm "Bash(mypy *)"
      echo -e "  ${GREEN}+${NC} mypy"
    fi
    if echo "$py_content" | grep -qi "streamlit"; then
      add_perm "Bash(streamlit *)"
      echo -e "  ${GREEN}+${NC} streamlit"
    fi
    if echo "$py_content" | grep -qi "uvicorn"; then
      add_perm "Bash(uvicorn *)"
      echo -e "  ${GREEN}+${NC} uvicorn"
    fi
    if echo "$py_content" | grep -qi "fastapi"; then
      add_perm "Bash(uvicorn *)" && add_perm "Bash(fastapi *)"
      echo -e "  ${GREEN}+${NC} fastapi"
    fi
    if echo "$py_content" | grep -qi "playwright"; then
      add_perm "Bash(playwright *)" && add_perm "Bash(python -m playwright *)"
      echo -e "  ${GREEN}+${NC} playwright (py)"
    fi
  fi
  [ -f "$proj_dir/.pre-commit-config.yaml" ] && add_perm "Bash(pre-commit *)" && echo -e "  ${GREEN}+${NC} pre-commit"

  # Apple / Xcode
  if [ -f "$proj_dir/Package.swift" ] || [ -f "$proj_dir/project.yml" ] || ls "$proj_dir"/*.xcodeproj 2>/dev/null | head -1 | grep -q .; then
    add_perm "Bash(swift *)"
    add_perm "Bash(swiftc *)"
    add_perm "Bash(xcodebuild *)"
    add_perm "Bash(xcode-select *)"
    add_perm "Bash(xcrun *)"
    add_perm "Bash(xcrun simctl *)"
    add_perm "Bash(plutil *)"
    add_perm "Bash(defaults *)"
    echo -e "  ${GREEN}+${NC} swift/xcode"
    if [ -f "$proj_dir/project.yml" ]; then
      add_perm "Bash(xcodegen *)"
      echo -e "  ${GREEN}+${NC} xcodegen"
    fi
  fi
  if [ -f "$proj_dir/Podfile" ]; then
    add_perm "Bash(pod *)"
    echo -e "  ${GREEN}+${NC} cocoapods"
  fi

  # Firebase
  if [ -f "$proj_dir/firebase.json" ] || [ -f "$proj_dir/.firebaserc" ]; then
    add_perm "Bash(firebase *)"
    echo -e "  ${GREEN}+${NC} firebase"
  fi

  # Build tools
  [ -f "$proj_dir/Cargo.toml" ] && add_perm "Bash(cargo *)" && add_perm "Bash(rustc *)" && echo -e "  ${GREEN}+${NC} rust"
  [ -f "$proj_dir/go.mod" ] && add_perm "Bash(go *)" && echo -e "  ${GREEN}+${NC} go"
  [ -f "$proj_dir/Gemfile" ] && add_perm "Bash(bundle *)" && add_perm "Bash(ruby *)" && add_perm "Bash(rake *)" && echo -e "  ${GREEN}+${NC} ruby"
  [ -f "$proj_dir/Makefile" ] && add_perm "Bash(make *)" && echo -e "  ${GREEN}+${NC} make"
  [ -f "$proj_dir/CMakeLists.txt" ] && add_perm "Bash(cmake *)" && add_perm "Bash(make *)" && echo -e "  ${GREEN}+${NC} cmake"
  if [ -f "$proj_dir/Dockerfile" ] || [ -f "$proj_dir/docker-compose.yml" ]; then
    add_perm "Bash(docker *)" && add_perm "Bash(docker-compose *)"
    echo -e "  ${GREEN}+${NC} docker"
  fi

  # SQLite
  if ls "$proj_dir"/*.db 2>/dev/null | head -1 | grep -q . || echo "${py_content:-}${pkg_content:-}" 2>/dev/null | grep -qi "sqlite"; then
    add_perm "Bash(sqlite3 *)"
    echo -e "  ${GREEN}+${NC} sqlite"
  fi

  # Project-local scripts
  if [ -d "$proj_dir/bin" ]; then
    add_perm "Bash(./bin/*)"
    echo -e "  ${GREEN}+${NC} ./bin/*"
  fi
  if [ -d "$proj_dir/scripts" ]; then
    add_perm "Bash(./scripts/*)"
    echo -e "  ${GREEN}+${NC} ./scripts/*"
  fi

  # --- Write settings.local.json ---
  if [ ${#perms[@]} -eq 0 ]; then
    echo -e "\n  ${YELLOW}No project-specific tools detected.${NC}"
    return
  fi

  local settings_dir="$proj_dir/.claude"
  local settings_file="$settings_dir/settings.local.json"
  mkdir -p "$settings_dir"

  # Build JSON allow array
  local json_perms=""
  for p in "${perms[@]}"; do
    [ -n "$json_perms" ] && json_perms+=","
    json_perms+=$'\n'"    \"$p\""
  done

  # If file exists, merge new permissions
  if [ -f "$settings_file" ]; then
    local existing_perms
    existing_perms="$(cat "$settings_file")"
    local added=0 kept=0
    local new_perms=()

    for p in "${perms[@]}"; do
      if echo "$existing_perms" | grep -qF "\"$p\""; then
        ((kept++))
      else
        new_perms+=("$p")
        ((added++))
      fi
    done

    if [ "$added" -eq 0 ]; then
      echo -e "\n  ${GREEN}Already up to date.${NC} ($kept existing permissions)"
      return
    fi

    # Rebuild: read existing allow array and append new ones
    # Simple approach: rewrite the whole file with merged permissions
    local all_existing
    all_existing="$(python3 -c "
import json, sys
with open('$settings_file') as f:
    data = json.load(f)
perms = data.get('permissions', {}).get('allow', [])
for p in perms:
    print(p)
" 2>/dev/null || true)"

    # Combine existing + new, deduplicate
    local all_perms=()
    while IFS= read -r line; do
      [ -n "$line" ] && all_perms+=("$line")
    done <<< "$all_existing"
    for p in "${new_perms[@]}"; do
      all_perms+=("$p")
    done

    # Rebuild JSON
    json_perms=""
    for p in "${all_perms[@]}"; do
      [ -n "$json_perms" ] && json_perms+=","
      json_perms+=$'\n'"    \"$p\""
    done

    cat > "$settings_file" <<EOJSON
{
  "permissions": {
    "allow": [$json_perms
    ],
    "deny": []
  }
}
EOJSON
    echo -e "\n  ${GREEN}Updated${NC} $settings_file"
    echo -e "  Added: $added | Kept: $kept"
  else
    cat > "$settings_file" <<EOJSON
{
  "permissions": {
    "allow": [$json_perms
    ],
    "deny": []
  }
}
EOJSON
    echo -e "\n  ${GREEN}Created${NC} $settings_file"
    echo -e "  Added: ${#perms[@]} permissions"
  fi
}

# --- Maintain (nightly) ---

# =============================================================================
# Agent Management
# =============================================================================

LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"

# Scan all projects for .claude/agents.json, output: project_dir|project_name|agent_name
agent_scan_all() {
  for proj_dir in "$PROJECTS_DIR"/*/; do
    [ ! -d "$proj_dir" ] && continue
    local agents_file="$proj_dir/.claude/agents.json"
    [ ! -f "$agents_file" ] && continue
    local proj_name
    proj_name="$(basename "$proj_dir")"
    # Parse agent names from JSON
    local agent_names
    agent_names="$(python3 -c "
import json, sys
with open('$agents_file') as f:
    data = json.load(f)
for name in data.get('agents', {}):
    print(name)
" 2>/dev/null)"
    while IFS= read -r aname; do
      [ -z "$aname" ] && continue
      echo "${proj_dir%/}|${proj_name}|${aname}"
    done <<< "$agent_names"
  done
}

# Resolve agent: returns project_dir|project_name|agent_name or exits
agent_resolve() {
  local name="$1"
  local project="${2:-}"
  local matches=()

  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local aname="${line##*|}"
    local pname
    pname="$(echo "$line" | cut -d'|' -f2)"
    if [ "$aname" = "$name" ]; then
      if [ -z "$project" ] || [ "$pname" = "$project" ]; then
        matches+=("$line")
      fi
    fi
  done < <(agent_scan_all)

  if [ "${#matches[@]}" -eq 0 ]; then
    echo -e "${RED}Agent not found:${NC} $name" >&2
    return 1
  elif [ "${#matches[@]}" -gt 1 ] && [ -z "$project" ]; then
    echo -e "${RED}Multiple agents named '$name' found. Use --project to disambiguate:${NC}" >&2
    for m in "${matches[@]}"; do
      local pn
      pn="$(echo "$m" | cut -d'|' -f2)"
      echo "  --project $pn" >&2
    done
    return 1
  fi

  echo "${matches[0]}"
}

# Get plist label for an agent
agent_plist_label() {
  local project="$1"
  local name="$2"
  echo "com.sk.agent.${project}.${name}"
}

# Check if agent is loaded in launchd
agent_is_loaded() {
  local label="$1"
  launchctl list "$label" &>/dev/null
}

# Get agent config field via python
agent_get_config() {
  local agents_file="$1"
  local agent_name="$2"
  local field="$3"
  python3 -c "
import json
with open('$agents_file') as f:
    data = json.load(f)
agent = data['agents']['$agent_name']
val = agent
for key in '$field'.split('.'):
    if isinstance(val, dict):
        val = val.get(key, '')
    else:
        val = ''
        break
if isinstance(val, list):
    print(' '.join(str(x) for x in val))
elif isinstance(val, bool):
    print(str(val).lower())
else:
    print(val if val != '' else '')
" 2>/dev/null
}

# Generate plist XML from agent config
generate_agent_plist() {
  local proj_dir="$1"
  local proj_name="$2"
  local agent_name="$3"
  local agents_file="$proj_dir/.claude/agents.json"

  local label
  label="$(agent_plist_label "$proj_name" "$agent_name")"

  local script
  script="$(agent_get_config "$agents_file" "$agent_name" "script")"
  local args_raw
  args_raw="$(agent_get_config "$agents_file" "$agent_name" "args")"
  local sched_type
  sched_type="$(agent_get_config "$agents_file" "$agent_name" "schedule.type")"
  local sched_hour
  sched_hour="$(agent_get_config "$agents_file" "$agent_name" "schedule.hour")"
  local sched_minute
  sched_minute="$(agent_get_config "$agents_file" "$agent_name" "schedule.minute")"
  local sched_weekday
  sched_weekday="$(agent_get_config "$agents_file" "$agent_name" "schedule.weekday")"
  local sched_interval
  sched_interval="$(agent_get_config "$agents_file" "$agent_name" "schedule.interval")"
  local logs_dir
  logs_dir="$(agent_get_config "$agents_file" "$agent_name" "logs")"
  [ -z "$logs_dir" ] && logs_dir="reports/"

  local full_script="$proj_dir/$script"
  local full_logs="$proj_dir/$logs_dir"
  mkdir -p "$full_logs"

  # Build ProgramArguments — use wrapper to avoid macOS TCC restrictions
  local wrapper="$HOME/.local/bin/sk-agent-run"
  local prog_args=""
  prog_args+="        <string>$wrapper</string>
        <string>$proj_dir</string>
        <string>$script</string>"
  if [ -n "$args_raw" ]; then
    for arg in $args_raw; do
      prog_args+="
        <string>$arg</string>"
    done
  fi

  # Build schedule section
  local schedule_xml=""
  case "$sched_type" in
    daily)
      schedule_xml="    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>$sched_hour</integer>
        <key>Minute</key><integer>$sched_minute</integer>
    </dict>"
      ;;
    weekdays)
      schedule_xml="    <key>StartCalendarInterval</key>
    <array>"
      for wd in 1 2 3 4 5; do
        schedule_xml+="
        <dict>
            <key>Weekday</key><integer>$wd</integer>
            <key>Hour</key><integer>$sched_hour</integer>
            <key>Minute</key><integer>$sched_minute</integer>
        </dict>"
      done
      schedule_xml+="
    </array>"
      ;;
    weekly)
      schedule_xml="    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>$sched_weekday</integer>
        <key>Hour</key><integer>$sched_hour</integer>
        <key>Minute</key><integer>$sched_minute</integer>
    </dict>"
      ;;
    interval)
      schedule_xml="    <key>StartInterval</key>
    <integer>$sched_interval</integer>"
      ;;
  esac

  cat <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$label</string>

    <key>ProgramArguments</key>
    <array>
$prog_args
    </array>

$schedule_xml

    <key>StandardOutPath</key>
    <string>${full_logs}${agent_name}-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${full_logs}${agent_name}-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:$HOME/.npm-global/bin:$HOME/.local/bin</string>
    </dict>
</dict>
</plist>
PLIST
}

# --- Agent subcommands ---

cmd_agent() {
  local subcmd="${1:-help}"
  shift || true
  case "$subcmd" in
    list)    cmd_agent_list "$@" ;;
    start)   cmd_agent_start "$@" ;;
    stop)    cmd_agent_stop "$@" ;;
    status)  cmd_agent_status "$@" ;;
    log)     cmd_agent_log "$@" ;;
    create)  cmd_agent_create "$@" ;;
    help|--help|-h) cmd_agent_help ;;
    *)
      echo -e "${RED}Unknown agent command:${NC} $subcmd"
      cmd_agent_help
      exit 1
      ;;
  esac
}

cmd_agent_help() {
  cat <<EOF
Usage: sk agent <command> [args]

Commands:
  list                        List all agents across projects
  start <name> [--project P]  Generate plist and load agent
  stop <name> [--project P]   Unload and remove agent plist
  status <name> [--project P] Show agent config, launchd status, last log
  log <name> [--project P] [--lines N]  Show agent log (default 50 lines)
      [--structured]  Show structured JSONL (thinking, tools, cost)
      [--thinking]    Show only thinking blocks
  create                      Scaffold new agent (interactive)
  help                        Show this help
EOF
}

cmd_agent_list() {
  echo -e "${CYAN}=== Agents ===${NC}"
  echo ""
  printf "  %-14s %-22s %-8s %-18s %s\n" "PROJECT" "AGENT" "TYPE" "SCHEDULE" "STATUS"
  printf "  %-14s %-22s %-8s %-18s %s\n" "-------" "-----" "----" "--------" "------"

  local count=0
  while IFS='|' read -r proj_dir proj_name agent_name; do
    [ -z "$agent_name" ] && continue
    local agents_file="$proj_dir/.claude/agents.json"
    local atype
    atype="$(agent_get_config "$agents_file" "$agent_name" "type")"
    local sched_type
    sched_type="$(agent_get_config "$agents_file" "$agent_name" "schedule.type")"
    local sched_hour
    sched_hour="$(agent_get_config "$agents_file" "$agent_name" "schedule.hour")"
    local sched_minute
    sched_minute="$(agent_get_config "$agents_file" "$agent_name" "schedule.minute")"
    local disabled
    disabled="$(agent_get_config "$agents_file" "$agent_name" "disabled")"

    local sched_display
    sched_minute="$(printf '%02d' "$sched_minute")"
    case "$sched_type" in
      daily)    sched_display="daily ${sched_hour}:${sched_minute}" ;;
      weekdays) sched_display="weekdays ${sched_hour}:${sched_minute}" ;;
      weekly)
        local wd
        wd="$(agent_get_config "$agents_file" "$agent_name" "schedule.weekday")"
        local wd_names=("Sun" "Mon" "Tue" "Wed" "Thu" "Fri" "Sat")
        sched_display="${wd_names[$wd]:-?} ${sched_hour}:${sched_minute}"
        ;;
      interval)
        local iv
        iv="$(agent_get_config "$agents_file" "$agent_name" "schedule.interval")"
        sched_display="every ${iv}s"
        ;;
      *) sched_display="$sched_type" ;;
    esac

    local label
    label="$(agent_plist_label "$proj_name" "$agent_name")"
    local status_str
    if [ "$disabled" = "true" ]; then
      status_str="${YELLOW}disabled${NC}"
    elif agent_is_loaded "$label"; then
      status_str="${GREEN}● loaded${NC}"
    else
      status_str="${RED}○ unloaded${NC}"
    fi

    printf "  %-14s %-22s %-8s %-18s " "$proj_name" "$agent_name" "$atype" "$sched_display"
    echo -e "$status_str"
    ((count++))
  done < <(agent_scan_all)

  echo ""
  echo -e "  ${CYAN}Total:${NC} $count agent(s)"
}

cmd_agent_start() {
  local name="" project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --project=*) project="${1#--project=}"; shift ;;
      *) name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    echo -e "${RED}Usage:${NC} sk agent start <name> [--project <proj>]"
    return 1
  fi

  local resolved
  resolved="$(agent_resolve "$name" "$project")" || return 1
  local proj_dir proj_name agent_name
  proj_dir="$(echo "$resolved" | cut -d'|' -f1)"
  proj_name="$(echo "$resolved" | cut -d'|' -f2)"
  agent_name="$(echo "$resolved" | cut -d'|' -f3)"

  local disabled
  disabled="$(agent_get_config "$proj_dir/.claude/agents.json" "$agent_name" "disabled")"
  if [ "$disabled" = "true" ]; then
    echo -e "${YELLOW}Agent '$agent_name' is disabled. Set disabled: false in agents.json first.${NC}"
    return 1
  fi

  # Auto-provision compiled wrapper binary if missing
  local wrapper="$HOME/.local/bin/sk-agent-run"
  if [ ! -x "$wrapper" ] || file "$wrapper" 2>/dev/null | grep -q "shell script"; then
    mkdir -p "$HOME/.local/bin"
    local swift_src="$wrapper.swift"
    cat > "$swift_src" <<'SWIFT'
import Foundation
let args = CommandLine.arguments
guard args.count >= 3 else { fputs("Usage: sk-agent-run <project_dir> <script> [args...]\n", stderr); exit(1) }
let projectDir = args[1]
let script = args[2]
let extraArgs = Array(args.dropFirst(3))
FileManager.default.changeCurrentDirectoryPath(projectDir)
let process = Process()
process.executableURL = URL(fileURLWithPath: "/bin/bash")
process.arguments = [script] + extraArgs
var env = ProcessInfo.processInfo.environment
env["PATH"] = (env["PATH"].map { $0 + ":" } ?? "") + "/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"
process.environment = env
do { try process.run(); process.waitUntilExit(); exit(process.terminationStatus) }
catch { fputs("Failed to run \(script): \(error)\n", stderr); exit(1) }
SWIFT
    if swiftc -O -o "$wrapper" "$swift_src" 2>/dev/null; then
      rm -f "$swift_src"
      echo -e "${GREEN}Compiled wrapper:${NC} $wrapper"
    else
      echo -e "${RED}Failed to compile wrapper. Install Xcode CLI tools: xcode-select --install${NC}"
      return 1
    fi
    echo ""
    echo -e "${YELLOW}┌─────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${YELLOW}│  One-time setup: grant Full Disk Access to the wrapper binary   │${NC}"
    echo -e "${YELLOW}│  System Settings → Privacy & Security → Full Disk Access        │${NC}"
    echo -e "${YELLOW}│  Click + → press Cmd+Shift+G → paste:                           │${NC}"
    echo -e "${YELLOW}│  ~/.local/bin/sk-agent-run                                      │${NC}"
    echo -e "${YELLOW}└─────────────────────────────────────────────────────────────────┘${NC}"
    echo ""
  fi

  local label
  label="$(agent_plist_label "$proj_name" "$agent_name")"
  local plist_path="$LAUNCH_AGENTS_DIR/${label}.plist"

  # Generate plist
  generate_agent_plist "$proj_dir" "$proj_name" "$agent_name" > "$plist_path"
  echo -e "${GREEN}Generated:${NC} $plist_path"

  # Load
  launchctl load "$plist_path" 2>/dev/null
  if agent_is_loaded "$label"; then
    echo -e "${GREEN}Loaded:${NC} $label"
  else
    echo -e "${RED}Failed to load:${NC} $label"
    return 1
  fi
}

cmd_agent_stop() {
  local name="" project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --project=*) project="${1#--project=}"; shift ;;
      *) name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    echo -e "${RED}Usage:${NC} sk agent stop <name> [--project <proj>]"
    return 1
  fi

  local resolved
  resolved="$(agent_resolve "$name" "$project")" || return 1
  local proj_name agent_name
  proj_name="$(echo "$resolved" | cut -d'|' -f2)"
  agent_name="$(echo "$resolved" | cut -d'|' -f3)"

  local label
  label="$(agent_plist_label "$proj_name" "$agent_name")"
  local plist_path="$LAUNCH_AGENTS_DIR/${label}.plist"

  if [ -f "$plist_path" ]; then
    launchctl unload "$plist_path" 2>/dev/null
    rm "$plist_path"
    echo -e "${GREEN}Stopped and removed:${NC} $label"
  else
    echo -e "${YELLOW}Plist not found:${NC} $plist_path"
    echo -e "Agent may not be started via sk. Checking launchd..."
    if agent_is_loaded "$label"; then
      launchctl remove "$label" 2>/dev/null
      echo -e "${GREEN}Removed from launchd:${NC} $label"
    else
      echo -e "${YELLOW}Not loaded in launchd either.${NC}"
    fi
  fi
}

cmd_agent_status() {
  local name="" project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --project=*) project="${1#--project=}"; shift ;;
      *) name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    echo -e "${RED}Usage:${NC} sk agent status <name> [--project <proj>]"
    return 1
  fi

  local resolved
  resolved="$(agent_resolve "$name" "$project")" || return 1
  local proj_dir proj_name agent_name
  proj_dir="$(echo "$resolved" | cut -d'|' -f1)"
  proj_name="$(echo "$resolved" | cut -d'|' -f2)"
  agent_name="$(echo "$resolved" | cut -d'|' -f3)"

  local agents_file="$proj_dir/.claude/agents.json"
  local label
  label="$(agent_plist_label "$proj_name" "$agent_name")"

  echo -e "${CYAN}=== Agent: $agent_name ===${NC}"
  echo ""

  # Config details
  local atype desc script sched_type sched_hour sched_minute logs_dir disabled
  atype="$(agent_get_config "$agents_file" "$agent_name" "type")"
  desc="$(agent_get_config "$agents_file" "$agent_name" "description")"
  script="$(agent_get_config "$agents_file" "$agent_name" "script")"
  sched_type="$(agent_get_config "$agents_file" "$agent_name" "schedule.type")"
  sched_hour="$(agent_get_config "$agents_file" "$agent_name" "schedule.hour")"
  sched_minute="$(agent_get_config "$agents_file" "$agent_name" "schedule.minute")"
  logs_dir="$(agent_get_config "$agents_file" "$agent_name" "logs")"
  disabled="$(agent_get_config "$agents_file" "$agent_name" "disabled")"
  [ -z "$logs_dir" ] && logs_dir="reports/"

  echo -e "  ${CYAN}Project:${NC}     $proj_name"
  echo -e "  ${CYAN}Type:${NC}        $atype"
  echo -e "  ${CYAN}Description:${NC} $desc"
  echo -e "  ${CYAN}Script:${NC}      $proj_dir/$script"
  echo -e "  ${CYAN}Schedule:${NC}    $sched_type ${sched_hour}:$(printf '%02d' "$sched_minute")"
  echo -e "  ${CYAN}Logs:${NC}        $proj_dir/$logs_dir"
  echo -e "  ${CYAN}Label:${NC}       $label"
  echo -e "  ${CYAN}Disabled:${NC}    ${disabled:-false}"
  echo ""

  # Launchd status
  if agent_is_loaded "$label"; then
    echo -e "  ${CYAN}launchd:${NC}     ${GREEN}● loaded${NC}"
    local exit_status
    exit_status="$(launchctl list "$label" 2>/dev/null | grep '"LastExitStatus"' | grep -oE '[0-9]+' || echo "?")"
    # Try parsing from launchctl list output
    if [ "$exit_status" = "?" ]; then
      exit_status="$(launchctl list 2>/dev/null | awk -v lbl="$label" '$3 == lbl {print $2}')"
    fi
    echo -e "  ${CYAN}Last Exit:${NC}   $exit_status"
  else
    echo -e "  ${CYAN}launchd:${NC}     ${RED}○ not loaded${NC}"
  fi
  echo ""

  # Token usage from structured log
  local structured_log
  structured_log="$(ls -t "$proj_dir/${logs_dir}"*structured.jsonl 2>/dev/null | head -1)"
  if [ -n "$structured_log" ] && [ -f "$structured_log" ]; then
    local usage_line
    usage_line="$(grep '"result"' "$structured_log" | tail -1)"
    if [ -n "$usage_line" ]; then
      echo -e "  ${CYAN}Last Run Usage:${NC}"
      python3 -c "
import json, sys
ev = json.loads(sys.argv[1])
inp = ev.get('input_tokens', 0)
out = ev.get('output_tokens', 0)
cost = ev.get('cost_usd', 0)
model = ev.get('model', '?')
print(f'    Model: {model}')
print(f'    Tokens: {inp/1000:.1f}K in + {out/1000:.1f}K out')
print(f'    Cost: \${cost:.2f}')
" "$usage_line" 2>/dev/null || true
      echo ""
    fi
  fi

  # Show last few log lines
  local stdout_log="$proj_dir/${logs_dir}${agent_name}-stdout.log"
  if [ -f "$stdout_log" ]; then
    echo -e "  ${CYAN}Recent log (last 10 lines):${NC}"
    tail -10 "$stdout_log" | sed 's/^/    /'
  else
    echo -e "  ${YELLOW}No log file found at $stdout_log${NC}"
  fi
}

cmd_agent_log() {
  local name="" project="" lines=50 structured=false thinking=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --project=*) project="${1#--project=}"; shift ;;
      --lines) lines="$2"; shift 2 ;;
      --lines=*) lines="${1#--lines=}"; shift ;;
      -n) lines="$2"; shift 2 ;;
      --structured) structured=true; shift ;;
      --thinking) thinking=true; shift ;;
      *) name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    echo -e "${RED}Usage:${NC} sk agent log <name> [--project <proj>] [--lines N] [--structured] [--thinking]"
    return 1
  fi

  local resolved
  resolved="$(agent_resolve "$name" "$project")" || return 1
  local proj_dir proj_name agent_name
  proj_dir="$(echo "$resolved" | cut -d'|' -f1)"
  proj_name="$(echo "$resolved" | cut -d'|' -f2)"
  agent_name="$(echo "$resolved" | cut -d'|' -f3)"

  local agents_file="$proj_dir/.claude/agents.json"
  local logs_dir
  logs_dir="$(agent_get_config "$agents_file" "$agent_name" "logs")"
  [ -z "$logs_dir" ] && logs_dir="reports/"

  # Structured log view
  if [ "$structured" = true ] || [ "$thinking" = true ]; then
    # Find most recent structured JSONL log
    local structured_log
    structured_log="$(ls -t "$proj_dir/${logs_dir}"*structured.jsonl 2>/dev/null | head -1)"
    if [ -z "$structured_log" ]; then
      echo -e "${YELLOW}No structured log found in $proj_dir/${logs_dir}${NC}"
      echo -e "Run agent with stream-json to generate structured logs."
      return 1
    fi

    echo -e "${CYAN}=== Structured Log: $agent_name ($proj_name) ===${NC}"
    echo -e "${CYAN}    File: $structured_log${NC}"
    echo ""

    local filter_type=""
    [ "$thinking" = true ] && filter_type="thinking"

    python3 -c "
import json, sys

filter_type = '$filter_type'
lines_limit = $lines
events = []

with open('$structured_log', 'r') as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except json.JSONDecodeError:
            continue
        if filter_type and ev.get('type') != filter_type:
            continue
        events.append(ev)

# Show last N events
for ev in events[-lines_limit:]:
    ts = ev.get('ts', '?')
    time_part = ts.split('T')[1] if 'T' in ts else ts
    etype = ev.get('type', '?')

    if etype == 'thinking':
        preview = ev.get('preview', '')[:80]
        print(f'[{time_part}] 🧠 Thinking ({ev.get(\"len\", 0)} chars): {preview}')
    elif etype == 'tool':
        name = ev.get('name', '?')
        inp = ev.get('input', '')
        # Try to extract key info from input JSON
        try:
            inp_obj = json.loads(inp)
            if 'file_path' in inp_obj:
                detail = inp_obj['file_path']
            elif 'query' in inp_obj:
                detail = '\"' + inp_obj['query'] + '\"'
            elif 'pattern' in inp_obj:
                detail = inp_obj['pattern']
            elif 'command' in inp_obj:
                detail = inp_obj['command'][:60]
            else:
                detail = inp[:60]
        except (json.JSONDecodeError, TypeError):
            detail = inp[:60]
        print(f'[{time_part}] 🔧 {name} → {detail}')
    elif etype == 'text':
        text = ev.get('text', '')[:80].replace(chr(10), ' ')
        print(f'[{time_part}] 💬 Text ({ev.get(\"len\", 0)} chars): {text}')
    elif etype == 'result':
        inp_t = ev.get('input_tokens', 0)
        out_t = ev.get('output_tokens', 0)
        cost = ev.get('cost_usd', 0)
        inp_k = f'{inp_t/1000:.1f}K'
        out_k = f'{out_t/1000:.1f}K'
        print(f'[{time_part}] 📊 Result: {inp_k} in + {out_k} out = \${cost:.2f}')
    else:
        print(f'[{time_part}] {etype}: {json.dumps(ev)[:80]}')
"
    return 0
  fi

  local stdout_log="$proj_dir/${logs_dir}${agent_name}-stdout.log"
  local stderr_log="$proj_dir/${logs_dir}${agent_name}-stderr.log"

  echo -e "${CYAN}=== Log: $agent_name ($proj_name) ===${NC}"
  echo ""

  if [ -f "$stdout_log" ]; then
    echo -e "${CYAN}--- stdout (last $lines lines) ---${NC}"
    tail -"$lines" "$stdout_log"
  else
    echo -e "${YELLOW}No stdout log: $stdout_log${NC}"
  fi

  if [ -f "$stderr_log" ] && [ -s "$stderr_log" ]; then
    echo ""
    echo -e "${CYAN}--- stderr (last 20 lines) ---${NC}"
    tail -20 "$stderr_log"
  fi
}

cmd_agent_create() {
  local name="" project="" atype="claude" description="" schedule_type="daily"
  local schedule_hour="8" schedule_minute="0"

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --project) project="$2"; shift 2 ;;
      --type) atype="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --schedule) schedule_type="$2"; shift 2 ;;
      --hour) schedule_hour="$2"; shift 2 ;;
      --minute) schedule_minute="$2"; shift 2 ;;
      *) [ -z "$name" ] && name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ] || [ -z "$project" ]; then
    echo -e "${RED}Usage:${NC} sk agent create <name> --project <proj> [--type claude|script] [--description '...'] [--schedule daily|weekdays|weekly] [--hour H] [--minute M]"
    return 1
  fi

  local proj_dir="$PROJECTS_DIR/$project"
  if [ ! -d "$proj_dir" ]; then
    echo -e "${RED}Project not found:${NC} $proj_dir"
    return 1
  fi

  [ -z "$description" ] && description="$name agent"

  # Scaffold script
  local scripts_dir="$proj_dir/scripts"
  local script_path="$scripts_dir/${name}.sh"
  mkdir -p "$scripts_dir"

  if [ ! -f "$script_path" ]; then
    cat > "$script_path" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

# Agent script — customize this for your use case
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TODAY="$(date '+%Y-%m-%d')"
MODE="${1:-daily}"

echo "[$TODAY] Running $MODE mode..."

# TODO: Add your agent logic here
# For Claude agents, use:
#   claude -p "your prompt" --output-format stream-json 2>&1

echo "[$TODAY] Done."
SCRIPT
    chmod +x "$script_path"
    echo -e "${GREEN}Created script:${NC} $script_path"
  else
    echo -e "${YELLOW}Script exists:${NC} $script_path"
  fi

  # Update or create agents.json
  local agents_file="$proj_dir/.claude/agents.json"
  mkdir -p "$proj_dir/.claude"

  python3 -c "
import json, os

agents_file = '$agents_file'
name = '$name'
data = {'agents': {}}

if os.path.exists(agents_file):
    with open(agents_file) as f:
        data = json.load(f)

if name in data.get('agents', {}):
    print(f'Agent \"{name}\" already exists in agents.json')
else:
    data.setdefault('agents', {})[name] = {
        'type': '$atype',
        'description': '$description',
        'script': 'scripts/${name}.sh',
        'schedule': {
            'type': '$schedule_type',
            'hour': int('$schedule_hour'),
            'minute': int('$schedule_minute')
        },
        'logs': 'reports/'
    }
    with open(agents_file, 'w') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.write('\n')
    print(f'Added \"{name}\" to agents.json')
"

  echo ""
  echo -e "${GREEN}Agent scaffolded.${NC} Next steps:"
  echo "  1. Edit $script_path"
  echo "  2. sk agent start $name --project $project"
}

# Agent health check — used by audit and maintain
agent_health_report() {
  local format="${1:-text}"  # text or markdown
  local issues=0

  while IFS='|' read -r proj_dir proj_name agent_name; do
    [ -z "$agent_name" ] && continue
    local agents_file="$proj_dir/.claude/agents.json"
    local sched_type sched_hour sched_minute disabled
    sched_type="$(agent_get_config "$agents_file" "$agent_name" "schedule.type")"
    sched_hour="$(agent_get_config "$agents_file" "$agent_name" "schedule.hour")"
    sched_minute="$(agent_get_config "$agents_file" "$agent_name" "schedule.minute")"
    disabled="$(agent_get_config "$agents_file" "$agent_name" "disabled")"
    sched_minute="$(printf '%02d' "$sched_minute")"

    local label
    label="$(agent_plist_label "$proj_name" "$agent_name")"

    local sched_display="${sched_type} ${sched_hour}:${sched_minute}"

    local status_str last_exit=""
    if [ "$disabled" = "true" ]; then
      status_str="disabled"
    elif agent_is_loaded "$label"; then
      status_str="● loaded"
      last_exit="$(launchctl list 2>/dev/null | awk -v lbl="$label" '$3 == lbl {print $2}')"
      [ -z "$last_exit" ] && last_exit="?"
    else
      status_str="○ unloaded"
      if [ "$disabled" != "true" ]; then
        issues=$((issues + 1))
      fi
    fi

    # Check last exit code
    if [ -n "$last_exit" ] && [ "$last_exit" != "0" ] && [ "$last_exit" != "?" ]; then
      issues=$((issues + 1))
    fi

    if [ "$format" = "markdown" ]; then
      echo "| $proj_name | $agent_name | $sched_display | $status_str | ${last_exit:-—} |"
    else
      printf "  %-14s %-22s %-18s %-12s %s\n" "$proj_name" "$agent_name" "$sched_display" "$status_str" "${last_exit:-—}"
    fi
  done < <(agent_scan_all)

  return "$issues"
}

cmd_maintain() {
  local today
  today="$(date '+%Y-%m-%d')"
  echo -e "${CYAN}=== Nightly Maintenance — $today ===${NC}\n"

  # 1. Deploy check: auto-deploy new skills, clean dangling symlinks
  echo -e "${CYAN}[1/4] Deploy Check${NC}"
  mkdir -p "$DEPLOY_TARGET"

  # Auto-deploy undeployed skills
  local deployed=0
  while IFS= read -r skill_dir; do
    [ -z "$skill_dir" ] && continue
    local name
    name="$(basename "$skill_dir")"
    local target="$DEPLOY_TARGET/$name"
    if [ ! -L "$target" ] && [ ! -e "$target" ]; then
      ln -s "$skill_dir" "$target"
      echo -e "  ${GREEN}deployed${NC} $name"
      ((deployed++))
    fi
  done < <(all_skill_dirs)

  # Clean dangling symlinks
  local cleaned=0
  for link in "$DEPLOY_TARGET"/*; do
    if [ -L "$link" ] && [ ! -e "$link" ]; then
      rm "$link"
      echo -e "  ${YELLOW}cleaned${NC} $(basename "$link") (dangling)"
      ((cleaned++))
    fi
  done

  if [ "$deployed" -eq 0 ] && [ "$cleaned" -eq 0 ]; then
    echo -e "  ${GREEN}All symlinks OK${NC}"
  else
    echo -e "  Deployed: $deployed | Cleaned: $cleaned"
  fi
  echo ""

  # 2. Permissions sync across all projects
  echo -e "${CYAN}[2/4] Permissions Sync${NC}"
  if [ -d "$PROJECTS_DIR" ]; then
    local proj_count=0
    for proj_dir in "$PROJECTS_DIR"/*/; do
      [ ! -d "$proj_dir" ] && continue
      local proj_name
      proj_name="$(basename "$proj_dir")"

      # Skip if no tooling indicators at all
      local has_tooling=0
      for indicator in package.json pyproject.toml requirements.txt Cargo.toml go.mod Gemfile Makefile Package.swift project.yml Podfile firebase.json .firebaserc Dockerfile; do
        if [ -f "$proj_dir/$indicator" ]; then
          has_tooling=1
          break
        fi
      done
      ls "$proj_dir"/*.xcodeproj 2>/dev/null | head -1 | grep -q . && has_tooling=1

      if [ "$has_tooling" -eq 1 ]; then
        echo -e "  ${CYAN}$proj_name${NC}"
        cmd_permissions "$proj_dir" 2>/dev/null | sed 's/^/    /'
        ((proj_count++))
      fi
    done
    echo -e "  Scanned: $proj_count projects"
  else
    echo -e "  ${YELLOW}Projects directory not found${NC}"
  fi
  echo ""

  # 3. Agent health check
  echo -e "${CYAN}[3/4] Agent Health${NC}"
  local agent_count=0
  agent_count="$(agent_scan_all | wc -l | tr -d ' ')"
  if [ "$agent_count" -gt 0 ]; then
    local agent_issues=0
    agent_health_report "text" || agent_issues=$?
    if [ "$agent_issues" -gt 0 ]; then
      echo -e "  ${YELLOW}$agent_issues agent issue(s) found${NC}"
    else
      echo -e "  ${GREEN}All agents healthy${NC}"
    fi
  else
    echo -e "  ${YELLOW}No agents configured${NC}"
  fi
  echo ""

  # 4. Audit report
  echo -e "${CYAN}[4/4] Audit Report${NC}"
  cmd_audit
}

cmd_audit() {
