    L_DATE="日期"; L_SESSIONS="Sessions"; L_API_CALLS="API 呼叫"; L_TOKENS="Tokens"; L_COST="預估花費"
    L_COST_BY_PROJECT="各專案花費（7 日）"
    L_PROJECT="專案"
    L_PRICING="計價: Opus input \$15/M, output \$75/M, cache create \$18.75/M, cache read \$1.50/M"
    L_GENERATED="由以下工具產生"
    L_AGENT_HEALTH="Agent 健康狀態"
    L_AGENT_PROJECT="專案"; L_AGENT_NAME="Agent"; L_AGENT_SCHED="排程"
    L_AGENT_STATUS="狀態"; L_AGENT_EXIT="最近 Exit"
    L_AGENT_ALL_OK="所有 agent 健康。"
    L_AGENT_ISSUES="個 agent 問題待處理。"
